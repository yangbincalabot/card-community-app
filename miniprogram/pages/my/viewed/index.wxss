page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.ct_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
}
.ct{
  width: 690rpx;
  margin: 0 auto;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}
.img{
  width: 138rpx;
  height: 138rpx;
  border-radius: 90rpx;
}
.img image{
  width: 138rpx;
  height: 138rpx;
  border-radius: 90rpx;
}
.text{
  margin-left: 30rpx;
  font-size: 24rpx;
  color: #707070;
  line-height: 50rpx;
}
.name{
  font-size: 28rpx;
  color: #000000;
}
.name span{
  height:38rpx;
  background:linear-gradient(180deg,rgba(153,153,153,1) 0%,rgba(0,0,0,1) 100%);
  border-radius:17rpx;
  font-size: 20rpx;
  color: #ffffff;
  padding: 5rpx 20rpx;
  margin-left: 48rpx;
}