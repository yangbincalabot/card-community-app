/* pages/address/index.wxss */
page{
	background: #F5F5F5;
}
.main {
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
}
.address_content{
	width: 750rpx;
	height: 220rpx;
	background: #FFFFFF;
	margin-top: 20rpx;
}
.add_name_phone{
	height: 135rpx;
	width: 690rpx;
	margin: 0 auto;
	border-bottom:1rpx solid rgb(229,229,229);
  position: relative;
  display: flex;
  
}
.name{
	font-size: 30rpx;
	color: rgb(51,51,51);
	padding-top: 20rpx;
}
.phone{
	font-size: 30rpx;
	color: rgb(51,51,51);
	margin-left: 30rpx;
}
.address{	
	font-size: 26rpx;
	color: rgb(51,51,51);
	overflow : hidden;
	text-overflow: ellipsis;
	-webkit-line-clamp: 1;
	-webkit-box-orient: vertical;
	display: -webkit-box;
  margin-top: 20rpx;
}
.operation{
	width: 690rpx;
	height: 84rpx;
	display: flex;
	margin: 0 auto;
	align-items: center;
	justify-content: space-between;
}
.left{
	font-size: 26rpx;
	color: rgb(255,168,0);
}
.right{
	display: flex;
	font-size: 26rpx;
	color: rgb(136,136,136);
}
.btn1{
	margin-right: 100rpx;
}
.btn{
	width: 750rpx;
	height: 98rpx;
	position: fixed;
	bottom: 0;	
	font-size: 32rpx;
	color: rgb(255,255,255);
	display: flex;
	justify-content: center;
	align-items: center;
	background: rgb(254,191,0);
}
icon{
  position: absolute;
  right: 0;
  top: 20rpx;
}

.bottom{
	height: 120rpx;
}