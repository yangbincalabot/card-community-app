page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  margin-bottom: 20rpx;
}
.search{
  width: 100%;
  height: 122rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.search_input{
  width:700rpx;
  height:74rpx;
  background: #F4F4F4;
  border-radius:14rpx;
}
input{
  width: 660rpx;
  height: 54rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
  text-align: center;
}
.ct_box{
  width: 100%;
  background:#ffffff;
  margin: 0 auto;
  margin-top: 20rpx;
}
.ct{
  width: 690rpx;
  margin: 0 auto;
  padding: 16rpx 0;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eeeeee;
}
.ct image{
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
}
.title{
  font-size: 32rpx;
  color: #000000;
}
.text{
  margin-left: 34rpx;
  font-size: 28rpx;
  color: #A4A4A4;
  line-height: 50rpx;
}
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
page{
  background: #f5f5f5;
}
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 20rpx;
}
.header .h-city {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  line-height: 1.0;
  letter-spacing: 0.4px;
  text-align: center;
  color: #a8a8a8;
}
.header .h-city image {
  width: 22rpx;
  height: 27rpx;
  margin-right: 16rpx;
}

.header .h-close image{
  width: 40rpx;
  height: 40rpx;
}
.now-city {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  background: #f2f4f5;
  font-size: 22rpx;
  line-height: 1.0;
  color: #a8a8a8;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #dbdbdb;
}
.now-city .now-city-name {
  display: flex;
  background: white;
  font-size: 30rpx;
  line-height: 1.0;
  letter-spacing: 0.4rpx;
  color: #333333;
  padding: 13rpx 33rpx;
  border: solid 1rpx #dbdbdb;
  margin-top: 18rpx;
}


.alphabet-list .section-item .section-item-header {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #181818;
  background-color: #f5f5f5;
  padding: 4rpx 26rpx;
}

.alphabet-list .section-item .section-item-cells {
  padding-left: 35rpx;
}
.alphabet-list .section-item .section-item-cells .section-item-cell{
  font-size: 30rpx;
  line-height: 1.0;
  color: #333333;
  padding: 16rpx 0;
  display: flex;
  align-items: center;
}
.alphabet-list .section-item .section-item-cells .section-item-cell text{
  padding-left: 35rpx;
  display: inline-block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.border-bottom {
  position: relative;
  border:none;
}

.border-bottom:after{
  content: '';
  position: absolute;
  bottom: 0;
  background: rgb(237, 237, 237);
  width: 85%;
  height: 1px;
  right: 0;
  -webkit-transform: scaleY(0.5);
  transform: scaleY(0.5);
  -webkit-transform-origin: 0 0;
  transform-origin: 0 0;
}
.alphanet-selector {
  position: absolute;
  top: 0rpx;
  right: 22rpx;
  height: 432px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  z-index: 100;
  box-sizing: border-box;
  margin-top: 230rpx;
  margin-left: 20rpx;

}
.bg{background-color: rgba(0,0,0, 0.2)}
.alphanet-selector .selector-one {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size:24rpx;
  color: #7D7D7D;
}
.avater{
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
}
