.show-alpha{
  width: 150rpx;
  height: 150rpx;
  background-color: rgba(0,0,0, 0.4);
  font-size: 50px;
  color: #fff;
  text-align: center;
  line-height: 150rpx;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  border-radius: 20rpx;
}
.card_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
}
.card_view{
  width: 690rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eeeeee;
  padding: 18rpx 0;
  margin: 0 auto;
}
.card{
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #878787;
}
.card image{
  width: 110rpx;
  height: 110rpx;
  border-radius: 90rpx;
}
.card_title{
  font-size: 32rpx;
  color: #000000;
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
}
.card_title span{
  font-size: 24rpx;
  color: #878787;
  margin-left: 34rpx;
}
.card_text{
  margin-left: 24rpx;
  font-size: 24rpx;
  color: #878787;
  line-height: 50rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.icontel{
  margin-right: 64rpx;
  font-size: 54rpx;
}
.site span{
  margin-left: 20rpx;
}
.num{
  width: 690rpx;
  height: 100rpx;
  font-size: 30rpx;
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}
.operate{
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 160rpx;
  color: #878787;
  font-size: 32rpx;
  margin-left: 12rpx;
}