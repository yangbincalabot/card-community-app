/* pages/bindingCard/bindingCard.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.search{
  width: 100%;
  height: 136rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
}
.search_input{
  width:560rpx;
  height:74rpx;
  background: #F4F4F4;
  border-radius:14rpx;
  margin-left: 20rpx;
}
input{
  width: 520rpx;
  height: 54rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
  text-align: center;
}
button{
  font-size: 36rpx;
  color: #FFC163;
  background: #ffffff;
}
.ct_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
  margin: 20rpx auto;
}
.ct_view{
  width: 690rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  margin: 0 auto;
}
.ct{  
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #878787;
}
.ct image{
  width: 110rpx;
  height: 110rpx;
}
.title{
  font-size: 28rpx;
  color: #343434;
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
}
.text{
  margin-left: 24rpx;
  font-size: 24rpx;
  color: #B5B5B5;
  line-height: 50rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.right{
  font-size: 36rpx;
  color: #FFC163;
  width: 85rpx;
}