<!--pages/my/editCard/editCard.wxml-->
<view class="main" hidden="{{ hidden }}">
  <view class="ct_box" bindtap="takePhoto">
    <span class="icon iconfont iconpaizhao"></span>

    <view>拍照识别</view>
  </view>
  <form bindsubmit="formSubmit">
    <view class="ct_view">
      <view class="ct" bindtap="UploadImage" data-type="avatar">
        <view class="ct_left">
          <text>头像</text>
        </view>
        <view class="ct_right">
          <image src="{{ avatar_url }}"></image>
          <span class="icon iconfont iconyoujiantou"></span>
        </view>
      </view>
      <view class="ct">
        <view class="ct_left">
          <text><text class="required">*</text>姓名</text>
          <input placeholder="请输入姓名" placeholder-class="placeholder" value="{{ formData.name ? formData.name : ''}}" name="name"></input>
        </view>
      </view>
      <view class="ct">
        <view class="ct_left">
          <text><text class="required">*</text>公司</text>
          <input placeholder="请输入公司名称" placeholder-class="placeholder" value="{{ formData.company_name ? formData.company_name : ''}}" name="company_name"></input>
        </view>
      </view>
      <picker mode="multiSelector" range="{{ industries }}" value="{{ industry_index }}" range-key="name" bindchange="changeIndustry" bindcolumnchange="changeIndustryIndex">
        <view class="ct">
          <view class="ct_left">
            <text><text class="required">*</text>行业</text>
            <input placeholder="{{ (industry_text.length === 0 || industry_text === '请选择所在行业') ? '请选择所在行业' :  '' }}" placeholder-class="placeholder" disabled="false" value="{{ industry_text !== '请选择所在行业' ? industry_text : ''}}"></input>
          </view>
          <view class="ct_right">
            <span class="icon iconfont iconyoujiantou"></span>
          </view>
        </view>
      </picker>
      <view class="ct">
        <view class="ct_left">
          <text><text class="required">*</text>职务</text>
          <input placeholder="请输入职位名称" placeholder-class="placeholder" value="{{ formData.position ? formData.position : ''}}" name="position"></input>
        </view>
        <view class="ct_right">
          <span class=""></span>
        </view>
      </view>
      <view class="ct">
        <view class="ct_left">
          <text><text class="required">*</text>手机</text>
          <input placeholder="请获取手机号" placeholder-class="placeholder" value="{{ formData.phone }}" name="phone"></input>
        </view>
        <block wx:if="{{ is_bind_phone === false }}">
          <button class="ct_right sms_button" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">
            <text>点击获取</text>
            <span class=""></span>
          </button>
        </block>
      </view>
    </view>
    <view class="ct_view">
      <view class="ct">
        <view class="ct_left">
          <text>微信</text>
          <input placeholder="请输入微信号" placeholder-class="placeholder" value="{{ formData.wechat ? formData.wechat : ''}}" name="wechat"></input>
        </view>
      </view>
      <view class="ct">
        <view class="ct_left">
          <text>邮箱</text>
          <input placeholder="请输入邮箱号" placeholder-class="placeholder" value="{{ formData.email ? formData.email : ''}}" name="email"></input>
        </view>
      </view>
      <view class="ct address">
        <view class="ct_left">
          <text>地址</text>
          <textarea placeholder="请完善地址" placeholder-class="placeholder" bindinput="changeAddressTitle" value="{{ formData.address_title ? formData.address_title : ''}}" name="address_title" auto-height></textarea>
        </view>
        <view class="ct_right" bindtap="getChooseLocation">
          <!-- <span class="icon iconfont iconla"></span> -->
          <image style="width:35rpx;height:50rpx;margin:0;" src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E5%AE%9A%E4%BD%8D%E5%9B%BE%E6%A0%87.png"></image>
        </view>
      </view>

      <block wx:for="{{ formData.tags }}" wx:key="index">

        <view class="ct address">
          <view class="ct_left">
            <text>标签{{ index + 1 }}</text>
            <textarea placeholder="{{ item ? '' : '添加你的个人印象标签' }}" placeholder-class="placeholder" name="tags[]" auto-height value="{{ item }}" bindinput="changeTag" data-index="{{ index }}"></textarea>
          </view>
          <block wx:if="{{ index === 0 }}">
            <view class="ct_right" bindtap="addTag">
              <span class="icon iconfont iconjia"></span>
              <!-- <image style="width:40rpx;height:40rpx;margin:0;" src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E6%B7%BB%E5%8A%A0%E5%9B%BE%E6%A0%87.png"></image> -->
            </view>
          </block>
          <block wx:else>
            <view class="ct_right" bindtap="deleteTag" data-index="{{ index }}">
              <span class="icon iconfont iconjinzhi"></span>
            </view>
          </block>
        </view>
      </block>
    </view>
    <view class="ct_view">
      <view class="ct address">
        <view class="ct_left">
          <text>简介</text>
          <textarea placeholder="请填写个人简介" placeholder-class="placeholder" value="{{ formData.introduction ? formData.introduction : ''}}" name="introduction"></textarea>
        </view>
        <view class="ct_right">
          <span class=""></span>
        </view>
      </view>
    </view>
    <view class="ct_view">
      <view class="ct address">
        <view class="ct_left">
          <text>相册</text>
        </view>
      </view>
      <view>
        <view class="img">
          <view class="img_box">
            <block wx:if="{{ formData.images.length < 9 }}">
              <span bindtap="UploadImage" data-type="images">
                <image src='https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/update.png'></image>
              </span>
            </block>
            <block wx:for="{{ formData.images }}" wx:key="index">
              <span>
                <image src='{{ item }}'></image>
                <i class="icon iconfont iconshanchu1" data-index="{{ index }}" bindtap="deleteImage"></i>
              </span>
            </block>
          </view>
        </view>
      </view>
    </view>
    <view class="ct_view">
      <block wx:if="{{ userInfo.companyCardStatus === true }}">
        <view class="ct address">
          <text>绑定企业名片</text>
          <view class="ct_right width_auto" wx:if="{{bind_company_name.length > 0}}">
            {{ bind_company_name }}
          </view>
          <view class="ct_right width_auto" wx:else bindtap="navigateToUrl" data-url="/pages/my/card/companyCard/index">
            去完善企业名片
            <i class="iconfont iconyoujiantou"></i>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="ct address" bindtap="bindingCard">
          <text>绑定企业名片</text>
          <view class="ct_right width_auto">
            <block wx:if="{{ bind_company_name }}">
              {{ bind_company_name }}
            </block>
            <block wx:else>
              请选择
            </block>
          </view>
        </view>
      </block>

    </view>
    <view class="ct_view">
      <view class="ct address">
        <text>名片公开</text>
        <view class="ct_right">
          <view bindtap="switchChange"  class="{{ is_open ? '' : 'weirz' }} switch_box">
            <image src="https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/switch_ioc.png"></image>
            {{ is_open ? '是': '否' }}
          </view>
          <!-- <switch color="#FFC163"  bindchange="changeOpen" checked="{{ is_open }}"/> -->
        </view>
      </view>
    </view>
    <view class="ct_view">
      <view class="ct address">
        <text>名片背景色</text>
        <view class="ct_right xz-view">

          <view data-id="1" bindtap="changeSellse">
             <image wx:if="{{ formData.card_color == 1 }}" src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/selected.png"></image>
             <image wx:else bindtap="changeSellse" src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/unselected.png"></image>
             <text>灰黑</text>
          </view>

          <view data-id="2" bindtap="changeSellse">
             <image wx:if="{{ formData.card_color == 2 }}"  src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/selected.png"></image>
             <image wx:else bindtap="changeSellse" src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/unselected.png"></image>
             <text>白</text>
          </view>
        </view>
      </view>
    </view>
    <!-- <view class="text" wx:if="{{ is_open }}">您的名片联系方式将会公开，访客可以直接查看，推荐销售人员使用。</view> -->
    <!-- <view class="text" wx:else>非主动转发时，您的联系方式将会被隐藏，成功交换名片后方可查看。</view> -->
    <view class="text">如果公开，其他人可以在名片广场看到您的名片</view>
    <cover-view class="coverBtn">
      <button form-type="submit">保存</button>
      <!-- <button>预览</button> -->
    </cover-view>
  </form>
</view>
