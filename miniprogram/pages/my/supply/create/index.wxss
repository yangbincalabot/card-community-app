/* pages/my/supply/create/index.wxss */
page{
  background: #f5f5f5;
  width: 100%;
  height: 100%;
}
.main{
  border-top: 1rpx solid #f5f5f5;
}
.text{
  width: 100%;
  height: 100%;
  background: #ffffff;
}
textarea{
  width: 690rpx;
  margin: 0 auto;
  padding: 20rpx 0;
}
.img{
  width: 100%;
  height: 100%;
  margin: 20rpx auto;
  background: #ffffff;
  padding: 20rpx 0;
  display: flex;
  justify-content: center;
}
.img_box{
  width: 690rpx;
  margin: 0 auto;
}
.img image{
  width: 180rpx;
  height: 180rpx;
  margin: 10rpx 25rpx;
}
.img_box span{
  position: relative;
}
.img_box i{
  position: absolute;
  right: 10rpx;
}
.ct_view{
  width: 100%;
  height: 100%;
  background: #ffffff;
  margin: 20rpx auto;
}
.ct{
  width: 690rpx;
  height: 100rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #353535;
  border-bottom: 1rpx solid #f5f5f5;
}
.ct_left{
  display: flex;
  align-items: center;
}
.ct_right{
  display: flex;
  align-items: center;
  color: #B5B5B5;
}
button{
  width:100%;
  height:90rpx;
  line-height: 90rpx;
  background:#FFA011;
  font-size: 32rpx;
  color: #FFFFFF;
  position: fixed;
  bottom: 0;
  border-radius: 0;
}
.iconshanchu1{
  color: #cdcdcd;
}