/* pages/my/supply/index/index.wxss */
page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
  padding-top: 20rpx;
}
.main .review{
  width: 750rpx;
  height: 100%;
  margin-bottom: 100rpx;
}
.main .review .review_content{
  width: 750rpx;
  margin-bottom: 20rpx;
  background: #fff;
}
.main .review .review_content .review_content_text{
  width: 690rpx;
  /* border-bottom: 1rpx solid rgb(229,229,229); */
  margin: 0 auto;
  display: flex;
  /* align-items: center; */
}
.main .review .review_content .review_content_text image{
  width: 150rpx;
  height: 150rpx;
  margin-top: 20rpx;
}
.main .review .review_content .review_content_text .text{
  margin-left: 20rpx;
  margin-top: 20rpx;
}
.main .review .review_content .review_content_text .text .title{
  font-size: 30rpx;
  color: rgb(51,51,51);
  overflow : hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.main .review .review_content .review_content_text .text .date{
  font-size: 28rpx;
  color: rgb(102,102,102);
  margin:24rpx 0;
}
.date span{
  margin-right: 20rpx;
}
.date span i{
  margin-left: 10rpx;
}
.main .review .opn{
  width: 690rpx;
  display: flex;
  justify-content: flex-end;
  margin: 0 auto;
  padding:10rpx 0 30rpx 0;
}
.main .review .opn .btn{
  display: flex;
}
.main .review .opn .btn .btn1{
  width: 120rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 14rpx;
  border: 1rpx solid #6db3f9;
  color: #6db3f9;
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.main .review .opn .btn .btn2{
  width: 120rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 14rpx;
  /* border: 1rpx solid rgb(254,191,0); */
  background: #6db3f9;
  color: #fff;
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 40rpx;
}
.addSupply{
  position: fixed;
  z-index: 999;
  right: 40rpx;
  bottom: 80rpx;
}
.iconjia1{
  font-size: 80rpx;
  color: #FFA011;
}