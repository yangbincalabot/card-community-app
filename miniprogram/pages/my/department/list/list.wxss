/* pages/mine/myaccount/tixian/index.wxss */
page{
    background: #f5f5f5;
}
.main{
    width: 750rpx;
    height: 100%;
    background: #f5f5f5;
    padding-top: 30rpx;
}
.main .title{
    margin-left: 30rpx;
    font-size: 28rpx;
    color: rgb(153,153,153);
}
.main .card{
    width: 690rpx;
    height: 100%;
    margin: 0 auto;
}
.main .card .card_content{
    width: 690rpx;
    height: 90rpx;
    background: rgb(255,254,255);
    border-radius: 20rpx;
    margin-top: 20rpx;
    display: flex;
    align-items: center;
    padding-left: 20rpx;
}
.main .card .card_content .logo{
    width: 70rpx;
    height: 70rpx;
    margin: 40rpx 30rpx;
}
.main .card .card_content .logo image{
    width: 70rpx;
    height: 70rpx;
}
.main .card .card_content .content{
    line-height: 60rpx;
}
.main .card .card_content .content .bank_title{
    font-size: 34rpx;
    color: rgb(51,51,51);
}
.main .card .card_content .content .name_account{
    font-size: 28rpx;
    color: rgb(102,102,102);
}
.main .card .card_content .content .name_account i{
    margin-left: 145rpx;
}
.main .btn{
    width: 590rpx;
    height: 94rpx;
    background: rgb(254,191,0);
    border-radius: 10rpx;
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 auto;
    margin-top: 90rpx;
    margin-bottom: 50rpx;
}