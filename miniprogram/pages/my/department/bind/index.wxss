/* pages/my/editCard/editCard.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.ct_box{
    width: 100%;
    height: 100rpx;
    background: #ffffff;
    font-size: 36rpx;
    color: #FFC163;
    display: flex;
    align-items: center;
    justify-content: center;
}
.ct_view{
    width: 100%;
    height: 100%;
    background: #ffffff;
    margin: 20rpx auto;
}
.ct{
    width: 690rpx;
    height: 100rpx;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 28rpx;
    color: #000000;
    border-bottom: 1rpx solid #f5f5f5;
}
.ct_left{
    display: flex;
    align-items: center;
    position: relative;
}
.ct_left text{
    width: 120rpx;
}
.placeholder{
    font-size: 32rpx;
    color: #cccccc;
}
.ct_left input {
    width: 470rpx;
    color: #1E1E1E;
    font-size: 32rpx;
    margin-left: 20rpx;
}
.ct_right{
    display: flex;
    align-items: center;
    color: #B5B5B5;
    width: 120rpx;
    justify-content: flex-end;
}
.ct_right image{
    width: 70rpx;
    height: 70rpx;
    border-radius: 90rpx;
    margin-right: 20rpx;
}
.ct_right text{
    font-size: 28rpx;
    color: #FFC163;
}
.address{
    height: 100%;
    padding: 30rpx 0;
}
.address textarea{
    width: 500rpx;
    margin-left: 20rpx;
}
.button{
    width: 100%;
    height: 90rpx;
    background:#FFC163;
    font-size: 32rpx;
    color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    bottom: 0;
    border-radius: 0;
    z-index:999
}
.text{
    width: 690rpx;
    margin: 20rpx auto;
    font-size: 28rpx;
    color: #B5B5B5;
    margin-bottom: 120rpx;
}
.iconpaizhao{
    font-size: 64rpx;
    margin-right: 20rpx;
}
.iconjinzhi{
    color: #ff0000;
}
.img{
    width: 100%;
    height: 100%;
    margin: 0 auto;
    background: #ffffff;
    padding: 20rpx 0;
    display: flex;
    justify-content: center;
}
.img_box{
    width: 690rpx;
    margin: 0 auto;
}
.img image{
    width: 180rpx;
    height: 180rpx;
    margin: 10rpx 25rpx;
}
.img_box span{
    position: relative;
}
.img_box i{
    position: absolute;
    right: 10rpx;
}
.iconshanchu1{
    color: #cdcdcd;
}

.sms_button{
    background: #fff;
    margin: 0;
    padding: 0;
}
.required{
    color:red;
    position:absolute;
    left: -15rpx
}

.width_auto{
    width: auto;
}