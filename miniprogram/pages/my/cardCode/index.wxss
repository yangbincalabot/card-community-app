/* pages/my/cardCode/cardCode.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.code{
  width: 690rpx;
  height: 780rpx;
  background:rgba(255,255,255,1);
  box-shadow:0rpx 0rpx 10rpx 0rpx rgba(183,183,183,0.5);
  border-radius:28px;
  margin: 24rpx auto;
  text-align: center;
}
.code_view{
  width: 450rpx;
  height: 568rpx;
  padding: 56rpx;
  margin: 0 auto;
}
.name{
  font-size: 36rpx;
  color: #000000;
}
.company{
  font-size: 28rpx;
  color: #979797;
  line-height: 60rpx;
}
.code_box{
  width: 400rpx;
  height: 400rpx;
  margin: 84rpx auto;
}
.code_box image{
  width: 400rpx;
  height: 400rpx;
}
.btn{
  width: 690rpx;
  margin: 24rpx auto;
  display: flex;
  align-items: center;
  justify-content: space-between;

}
button{
  width: 330rpx;
  height: 90rpx;
  border: 14rpx;
  font-size: 32rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn1{
  background: #F89417;
}
.btn2{
  background:#50a6f9;
}