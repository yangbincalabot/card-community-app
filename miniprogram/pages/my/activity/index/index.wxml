<!--pages/my/activity/index/index.wxml-->
<view class="main" bindtap="closeActive">
  <view class="swiper-tab">
    <view class="swiper-tab-item {{currentTab==1?'active':''}}" data-current="1" bindtap="clickTab">我参与的</view>
    <view class="swiper-tab-item {{currentTab==2?'active':''}}" data-current="2" bindtap="clickTab">我创建的</view>
  </view>
  <view class="{{currentTab==1 ? 'show':'hidden'}}">
    <view class='content'>
      <view class="ct_view">
        <block wx:for="{{ joinlist }}" wx:key="item">
          <view class='review_content'>
            <view class='order'>
              <view>订单号：{{item.order_no}}</view>
              <view>{{item.status_show}}</view>
            </view>
            <view class='review_content_text' bindtap="navigateToUrl" data-url="../orderDetail/index?id={{ item.id }}">
              <view class='text'>
                <view class='title'>
                  {{item.activity.title}}
                </view>
                <view class='date'>
                  <view>活动时间：
                    <i>{{item.activity.activity_time}}</i>
                  </view>
                </view>
                <view class='date'>
                  <view>活动地址：
                    <i>{{item.activity.address_title}}</i>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
  <view class="{{currentTab==2 ? 'show':'hidden'}}">
    <view class='content'>
      <view class="ct_view">
        <block wx:for="{{ list }}" wx:key="{{ item }}">
          <view class="active_box">
            <view class="active_view">
              <view class="ct">
                <view class="img">
                  <image src="{{item.cover_image}}"></image>
                </view>
                <view class="text">
                  <view class="ct_title">{{item.title}}</view>
                  <view class="ct_time">报名截止时间：{{item.apply_end_time}}</view>
                  <view class="ct_status">
                    <view class="ct_num">{{item.applyNum}}人已参与</view>
                    <view class="ct_sta" style="{{ (item.status_type == 4) ? 'background:#D8D8D8' : ''}}">{{item.status_show}}</view>
                  </view>
                </view>
              </view>
              <view class="btn">
                <button wx:if="{{ item.status_type == 4  && item.type == 2}}" bindtap="navigateToUrl" data-url="../tricks/index?aid={{ item.id }}" hover-class="none">会后花絮</button>
                <button wx:if="{{ item.status_type != 5 }}" bindtap="navigateToUrl" data-url="../applyList/index?id={{ item.id }}" hover-class="none">统计数据</button>
                <!-- <button wx-if="{{ item.status_type == 1 }}" bindtap="toCreateUrl" hover-class="none" data-type="{{ item.type }}" data-id="{{ item.id }}">编辑</button> -->
                <button wx:if="{{ item.status_type == 1 }}" bindtap="cancelActivity" data-id="{{ item.id }}" hover-class="none">取消活动</button>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

  </view>

  <view class="add" catchtap="addActive">
    <view class="icon iconfont iconjia1"></view>
  </view>
  <view wx-if="{{active}}" class="activeShow">
    <view class="add_box">
      <view class="addActive" bindtap="navigateToUrl" data-url="../activityCreate/index">
        <view>
          <view>创建</view>
          <view>活动</view>
        </view>
      </view>
      <view class="meeting" bindtap="navigateToUrl" data-url="../meetingCreate/index">
        <view>
          <view>创建</view>
          <view>会务</view>
        </view>
      </view>
    </view>
  </view>

</view>
