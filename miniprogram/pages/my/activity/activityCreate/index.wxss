/* pages/my/activity/activityCreate/index.wxss */
/* pages/my/addActive/addActive.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.imgs{
    width: 100%;
    height: 300rpx;
    position: relative;
}
.imgs image{
    width: 100%;
    height: 300rpx;
}
.imgBtn{
    height:50rpx;
    background:#FFC163;
    border-radius:20rpx;
    padding: 0 20rpx;
    font-size: 28rpx;
    color: #ffffff;
    position: absolute;
    z-index: 999;
    right: 16rpx;
    top: 22rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}
.input_box{
    width: 100%;
    background: #ffffff;
}
.input_box input{
    width: 690rpx;
    height: 150rpx;
    font-size: 28rpx;
    color: #545454;
    margin: 0 auto;
    border-bottom: 1rpx solid #f5f5f5;
}
.text{
    width: 100%;
    height: 100%;
    background: #ffffff;
}
textarea{
    width: 690rpx;
    margin: 0 auto;
    padding: 20rpx 0;
    font-size: 28rpx;
    color: #333333;
}
.img{
    width: 100%;
    height: 100%;
    margin: 0 auto;
    background: #ffffff;
    padding: 20rpx 0;
    display: flex;
    justify-content: center;
}
.img_box{
    width: 690rpx;
    margin: 0 auto;
}
.img image{
    width: 180rpx;
    height: 180rpx;
    margin: 10rpx 25rpx;
}
.img_box span{
    position: relative;
}
.img_box i{
    position: absolute;
    right: 10rpx;
}
.ct_view{
    width: 100%;
    height: 100%;
    background: #ffffff;
    margin: 20rpx auto;
}
.ct{
    width: 690rpx;
    height: 100rpx;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 28rpx;
    color: #353535;
    border-bottom: 1rpx solid #f5f5f5;
}
.ct_left{
    display: flex;
    align-items: center;
}
.ct_right{
    display: flex;
    align-items: center;
    color: #B5B5B5;
}
.jia_ct_right{
  width: 300rpx;
  justify-content: flex-end;
}
button{
  width: 100%;
  height: 90rpx;
  background:#FFC163;
  border-radius:0;
  font-size: 32rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  position: fixed;
  bottom: 0;
  z-index: 2;
}
.msg_button{
  margin-bottom: 120rpx !important;
}
.iconshanchu1{
    color: #cdcdcd;
}
.iconjinzhi{
    color: #FFC163;
    margin-right: 15rpx;
    font-size: 34rpx;
}
.ct_msg{
    width: 690rpx;
    margin: 0 auto;
    padding: 20rpx 0;
    border-bottom: 1rpx solid #f5f5f5;
}
.ct_text{
    font-size: 28rpx;
    color: #545454;
    line-height: 40rpx;
}
.ct_text span{
    margin-left: 20rpx;
}
.address{
    height: 100%;
    padding: 20rpx 0;
}
.address textarea{
    width: 530rpx;
    margin-left: 30rpx;
    text-align: right;
}
.placeholder{
    font-size: 28rpx;
    color: #B5B5B5;
}
.iconyoujiantou{
    margin-left: 40rpx;
}

.ct_right .text_address{
    text-align: left !important;
}
.company_name span{
    font-size: 26rpx;
    color: #666666;
}
.company_name .iconjinzhi{
    margin-left: 5rpx;
    color: #FFC163;
    margin-right: 10rpx;
    font-size: 34rpx;
}