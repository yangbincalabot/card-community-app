/* pages/my/activity/applyList/index.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.static_box{
  width:750rpx;
  height:256rpx;
  background:linear-gradient(180deg,rgba(255,200,118,1) 0%,rgba(255,154,1,1) 100%);  
  display: flex;
  align-items: center;
  justify-content: center;
}
.static_view{
  width: 560rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  margin: 0 auto;
  justify-content: space-between;
  color: #ffffff;
  text-align: center;
  font-size: 32rpx;
  line-height: 60rpx;
}
.line{
  width: 1rpx;
  height: 96rpx;
  background: #ffffff;
}
.num{
  font-size: 44rpx;
}
.ct_box{
  width: 100%;
  margin: 20rpx auto;
}
.ct{
  width: 100%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
}
.ct_right{
  width: 586rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #E9E9E9;
  padding: 20rpx 0;
}
.img image{
  width: 98rpx;
  height: 98rpx;
  border-radius: 90rpx;
}
.ct_right_box{
  display: flex;
  align-items: center;
}
.ct_text{
  margin-left: 24rpx;
  font-size: 28rpx;
  color: #000000;
  line-height: 50rpx;
}
.time{
  color: #B5B5B5;
}
.ct_right_view{
  font-size: 32rpx;
  color: #464646;
}