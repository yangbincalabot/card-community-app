<!--pages/my/activity/applyDetail/index.wxml-->
<view class="main">
  <view class="top">
    报名成功
  </view>
  <view class="ct_box">
    <view class="ct">
      报名人信息
    </view>
    <view class="msg">
      <view class="img">
        <image src="{{ detail.carte.avatar }}"></image>
      </view>
      <view class="text">
        <view class="text_title">{{ detail.carte.name }}</view>
        <button bindtap="navigateToUrl" data-url="/pages/card/other/index?id={{ detail.carte.id }}">查看名片</button>
      </view>
    </view>
    <view class="ct">
      <view class="ct_left">姓名</view>
      <view class="ct_right">
        {{ detail.name }}
      </view>
    </view>
    <view class="ct">
      <view class="ct_left">手机号</view>
      <view class="ct_right">
        {{ detail.phone }}
      </view>
    </view>
    <view class="ct">
      <view class="ct_left">工作单位</view>
      <view class="ct_right">
        {{ detail.company_name }}
      </view>
    </view>
    <view class="ct">
      <view class="ct_left">报名类别</view>
      <view class="ct_right">
        {{ detail.specification.title }}
      </view>
    </view>
  </view>
</view>

