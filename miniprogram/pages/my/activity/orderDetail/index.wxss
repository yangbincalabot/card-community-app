/* pages/my/activity/orderDetail/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.active_msg{
    width: 100%;
    height: 100%;
    background: #ffffff;
}
.active_box{
    width: 690rpx;
    margin: 0 auto;
    font-size: 28rpx;
    color: #000000;
}
.title{
    padding-top: 16rpx;
}
.msg{
    width: 690rpx;
    margin: 20rpx auto;
    display: flex;
    align-items: center;
}
.msg image{
    width: 186rpx;
    height: 154rpx;
    border-radius: 10rpx;
}
.text{
    width: 486rpx;
    margin-left: 18rpx;
}
.text_title{
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
    font-size: 28rpx;
    color: #000000;
}
.price_box{
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 44rpx;
    color: #FF9300;
    margin-top: 24rpx;
}
.price_box text{
    height:54rpx;
    border-radius:14rpx;
    font-size: 28rpx;
    color: #FF9300;
    line-height: 40rpx;
    padding: 0 20rpx;
    border: 1rpx solid #FF9300;
    display: flex;
    align-items: center;
    justify-content: center;
}
.ct_box{
    width: 100%;
    background: #ffffff;
    margin: 20rpx auto;
}
.ct{
    width: 690rpx;
    padding: 30rpx 0;
    border-bottom: 1rpx solid #eeeeee;
    margin: 0 auto;
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #000000;
}
.ct span{
    margin-left: 34rpx;
}
.ctName{
    border-bottom: 1rpx solid #ffffff;
}
.ctAccount{
    justify-content: flex-end;
    border-bottom: 1rpx solid #ffffff;
}
.orderdetail_msg{
    width: 750rpx;
    height: 100%;
    background: #fff;
    font-size: 28rpx;
    color: #A1A1A1;
    margin-bottom: 120rpx;
}
.msg_service{
    margin: 40rpx 20rpx;
}
.msg_service .s{
    display: flex;
    justify-content: flex-start;
    padding: 20rpx 0;
}
.btn{
    width: 100%;
    height: 100rpx;
    background: #ffffff;
    position: fixed;
    bottom: 0;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}
.btn1,.btn2{
    height: 50rpx;
    border-radius: 20rpx;
    padding: 0 20rpx;
    border: 1rpx solid #cccccc;
    font-size: 26rpx;
    color: #333333;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20rpx;
}
.price{
  font-size: 44rpx;
  color: #FF9300;
}