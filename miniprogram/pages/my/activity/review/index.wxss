/* pages/my/activity/review/index.wxss */
page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
  padding-top: 20rpx;
}
.main .review{
  width: 750rpx;
  height: 100%;
  margin-bottom: 100rpx;
}
.main .review .review_content{  
  width: 750rpx;
  height: 322rpx;
  margin-bottom: 20rpx;
  background: #fff;
}
.main .review .review_content .review_content_text{
  width: 690rpx;
  height: 210rpx;
  border-bottom: 1rpx solid rgb(229,229,229);
  margin: 0 auto;
  display: flex;
  /* align-items: center; */
}
.main .review .review_content .review_content_text image{
  width: 150rpx;
  height: 150rpx;
  margin-top: 20rpx;
}
.main .review .review_content .review_content_text .text{
  margin-left: 20rpx;
  margin-top: 20rpx;
}
.main .review .review_content .review_content_text .text .title{
  font-size: 30rpx;
  color: rgb(51,51,51);  
  overflow : hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.main .review .review_content .review_content_text .text .date{
  font-size: 28rpx;
  color: rgb(102,102,102);
  margin: 50rpx 0 30rpx 0;
}
.main .review .opn{
  width: 690rpx;
  display: flex;
  justify-content: space-between;
  margin: 0 auto;
}
.main .review .opn .left{
  margin-top: 45rpx;
  font-size: 24rpx;
  color: rgb(136,136,136);
}
.main .review .opn .btn{
  display: flex;
  margin-top: 30rpx;
}
.main .review .opn .btn .btn1{
  width: 120rpx;
  height: 50rpx;
  border-radius: 25rpx;
  border: 1rpx solid rgb(204,204,204);
  color: rgb(136,136,136);
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.main .review .opn .btn .btn2{
  width: 120rpx;
  height: 50rpx;
  border-radius: 25rpx;
  border: 1rpx solid rgb(254,191,0);
  color: rgb(254,191,0);
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 40rpx;
}
.main .payment{
  width: 750rpx;
  height: 98rpx;
  position: fixed;
  bottom: 0;
  background: rgb(254,191,0);
  font-size: 32rpx;
  color: rgb(255,255,255);
  display: flex;
  justify-content: center;
  align-items: center;
}