/* pages/my/activity/review/create/index.wxss */
@import "/utils/assets/iconfont.wxss";
/* page{
	background: #f5f5f5;
} */
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
}
.main .header{
  width: 750rpx;
  height: 224rpx;
  background: #fff;
  font-size: 30rpx;
  color: rgb(51,51,51);
  padding-top: 10rpx;
}
.main .header text{
  margin: 30rpx;
}
.main .header image{
  width: 116rpx;
  height: 116rpx;
  margin: 30rpx;
}
.main .text{
  width: 750rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  background: #fff;
  margin: 20rpx 0;
  font-size: 30rpx;
  color: #000; 
}
.main .text text{
  margin-left: 30rpx;
}
.main .text input{
  width: 60%;
  margin-left: 80rpx;
}
.main .textarea{
  width: 750rpx;
  background: #fff;
	padding-bottom: 30upx;
}
.text_box{
	border: 1rpx solid #ccc;
	border-radius: 10rpx;
	margin: 20rpx auto;
	width: 700rpx;
	min-height: 300rpx;
	text-align: center;
	padding-top: 20rpx;
}
.main .textarea .t{
  width: 700rpx;
  margin: 0 auto; 
  position: relative;
  font-size: 30rpx;
	padding: 30rpx 0;
	display: flex;	
	align-items: center;
	justify-content: space-between;
}
.main .textarea .t text{
  font-size: 30rpx;
  color: #000;
}
.main .textarea textarea{
  width: 670rpx;
  height: 520rpx;
  border: 1rpx solid rgb(204,204,204);
  border-radius: 1rpx;
  margin-top: 30rpx;
  font-size: 28rpx;
  padding: 10rpx;
}
.main .textarea editor{
  width: 670rpx;
  /* height: 520rpx; */
  border: 1rpx solid rgb(204,204,204);
  border-radius: 1rpx;
  margin-top: 30rpx;
  font-size: 28rpx;
  padding: 10rpx;
}
.main .t .btn{
  width: 136rpx;
  height: 44rpx;
  background: rgb(254,191,0);
  border-radius: 22rpx;
  font-size: 26rpx;
  color: #fff;
  text-align: center;
  position: absolute;
  left: 20rpx;
  bottom: 20rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	line-height: 48rpx;

}
.main .btn_bottom{
  display: flex;
  justify-content: space-around;
  padding: 60rpx 0;
}
.main .btn_bottom .btn1{
  width: 260rpx;
  height: 94rpx;
  border-radius: 10rpx;
  color: rgb(254,191,0);
  border: 1rpx solid rgb(254,191,0);
  display: flex;
  justify-content: center;
  align-items: center;
	line-height: 48rpx;
}
.main .btn_bottom .btn2{
  width: 260rpx;
  height: 94rpx;
  border-radius: 10rpx;
  color: #fff;
  background: rgb(254,191,0);
  display: flex;
  justify-content: center;
  align-items: center;
	line-height: 48rpx;
}
button::after{ border: none; }