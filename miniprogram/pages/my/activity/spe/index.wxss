/* pages/my/activity/spe/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.ct_view{
    width: 100%;
    height: 100%;
    background: #ffffff;
    margin: 20rpx auto;
}
.ct{
    width: 690rpx;
    height: 100rpx;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 28rpx;
    color: #000000;
    border-bottom: 1rpx solid #f5f5f5;
}
.ct_left{
    display: flex;
    align-items: center;
}
.placeholder{
    font-size: 28rpx;
    color: #cccccc;
    text-align: right;
}
input {
    width: 470rpx;
    color: #1E1E1E;
    font-size: 28rpx;
    margin-left: 20rpx;
    text-align: right;
}
.ct_right{
    display: flex;
    align-items: center;
    color: #B5B5B5;
}
button{
  width:100%;
  height:90rpx;
  background:#FFC163;
  font-size: 32rpx;
  color: #FFFFFF;
  position: fixed;
  bottom: 0;
  border-radius: 0;
}