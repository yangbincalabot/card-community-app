/* pages/my/activity/agenda/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.ct_view{
    width: 100%;
    height: 100%;
    background: #ffffff;
    margin: 20rpx auto;
}
.ct{
    width: 690rpx;
    height: 100rpx;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 28rpx;
    color: #040404;
    border-bottom: 1rpx solid #f5f5f5;
}
.ct_left{
    display: flex;
    align-items: center;
}
input {
    width: 470rpx;
    color: #040404;
    font-size: 32rpx;
    margin-left: 20rpx;
    text-align: right;
}
.ct_right{
    display: flex;
    align-items: center;
    color: #040404;
}
.placeholder{
    font-size: 28rpx;
    color: #A1A1A1;
}
.btn2{
    width:100%;
    height:90rpx;
    line-height: 90rpx;
    background:#dd7810;
    font-size: 32rpx;
    color: #FFFFFF;
    position: fixed;
    bottom: 120rpx;
    border-radius: 0;
}
.btn1{
  width:100%;
  height:90rpx;
  line-height: 90rpx;
  background:#FFC163;
  font-size: 32rpx;
  color: #FFFFFF;
  position: fixed;
  bottom: 0;
  border-radius: 0;
}
.ct_text{
    width: 690rpx;
    margin: 0 auto;
    font-size: 26rpx;
    color: #040404;
    padding: 20rpx 0;
}
textarea{
    width: 690rpx;
    margin: 20rpx 0;
}