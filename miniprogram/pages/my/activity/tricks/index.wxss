/* pages/my/activity/tricks/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.text{
    width: 100%;
    height: 100%;
    background: #ffffff;
}
textarea{
    width: 690rpx;
    margin: 0 auto;
    padding: 20rpx 0;
    font-size: 28rpx;
    color: #333333;
}
.img{
    width: 100%;
    height: 100%;
    margin: 0 auto;
    background: #ffffff;
    padding: 20rpx 0;
    display: flex;
    justify-content: center;
}
.img_box{
    width: 690rpx;
    margin: 0 auto;
}
.img image{
    width: 180rpx;
    height: 180rpx;
    margin: 10rpx 25rpx;
}
.img_box span{
    position: relative;
}
.img_box i{
    position: absolute;
    right: 10rpx;
}
button{
  width: 100%;
  height: 90rpx;
  background:#FFC163;
  font-size: 32rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  position: fixed;
  bottom: 0;
  border-radius: 0;
}
.iconshanchu1{
    color: #cdcdcd;
}