/* pages/card/group/create/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.main{
  padding-bottom: 120rpx;
}
.search{
    width: 100%;
    height: 122rpx;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
}
.search_input{
    width:700rpx;
    height:74rpx;
    background: #F4F4F4;
    border-radius:14rpx;
}
input{
    width: 660rpx;
    height: 54rpx;
    padding: 10rpx 20rpx;
    font-size: 28rpx;
    color: #333333;
    text-align: center;
}
.initial{
    font-size: 20rpx;
    color: #4F4F4F;
    width: 690rpx;
    margin: 4rpx auto;
}
.ct_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
}
.ct_view{
    width: 690rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1rpx solid #eeeeee;
    padding: 18rpx 0;
    margin: 0 auto;
}
.ct{
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #878787;
}
.ct image{
    width: 110rpx;
    height: 110rpx;
    border-radius: 90rpx;
}
.title{
    font-size: 32rpx;
    color: #000000;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
}
.title span{
    font-size: 24rpx;
    color: #878787;
    margin-left: 34rpx;
}
.text{
    margin-left: 24rpx;
    font-size: 24rpx;
    color: #878787;
    line-height: 50rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
button{
    width:750rpx;
    height:94rpx;
    background:linear-gradient(180deg,rgba(131,131,131,1) 0%,rgba(2,2,2,1) 100%);
    position: fixed;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    border-radius: 0;
}
.content{
    margin-bottom: 120rpx;
}