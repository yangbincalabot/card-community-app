/* pages/mine/myaccount/index.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.wallet_box{
  width: 100%;
  height: 232rpx;
  background:linear-gradient(180deg,rgba(255,199,115,1) 0%,rgba(255,158,10,1) 100%);
  color: #ffffff;
}
.account_view{
  width: 690rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
}
.account_box{
  line-height: 60rpx;
}
.account_title{
  font-size: 28rpx;
}
.account{
  font-size: 64rpx;
}
.cashOut{
  width:176rpx;
  height:148rpx;
  background:rgba(255,255,255,1);
  box-shadow:0rpx 2rpx 8rpx 2rpx rgba(181,113,8,1);
  border-radius:14rpx;
  color: #FF9F0E;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ct_view{
  width: 100%;
  margin: 20rpx auto;
  background: #ffffff;
}
.ct_box{
  width: 690rpx;
  height: 100rpx;
  font-size: 28rpx;
  color: #949494;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 auto;
  border-bottom: 1rpx solid #f5f5f5;
}