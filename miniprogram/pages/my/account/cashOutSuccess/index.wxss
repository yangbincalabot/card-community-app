/* pages/paysuccess/index.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
}
.pay_box{
  width: 100%;
  background: #ffffff;
  padding: 52rpx 0;
}
.main .pay{
  width: 590rpx;
  margin: 0 auto;
  text-align: center;
}
.main .pay image{
  width: 140rpx;
  height: 140rpx;
}
.main .pay .p1{
  font-size: 36rpx;
  color: #636363;
  margin: 30rpx 0;
}
.main .pay .p2{
  font-size: 24rpx;
  color: #636363;
  margin-bottom: 20rpx;
}
.back{
  width:612rpx;
  height:90rpx;
  background:linear-gradient(180deg,rgba(132,132,132,1) 0%,rgba(0,0,0,1) 100%);
  border-radius:14rpx;
  font-size: 34rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 62rpx auto;
}