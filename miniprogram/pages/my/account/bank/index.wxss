/* pages/mine/myaccount/tixian/index.wxss */
page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
  padding-top: 30rpx;
}
.main .title{
  margin-left: 30rpx;
  font-size: 28rpx;
  color: rgb(153,153,153);
}
.main .card{
  width: 690rpx;
  height: 100%;
  margin: 0 auto;
}
.main .card .card_content{
  width: 690rpx;
  height: 150rpx;
  background: rgb(255,254,255);
  border-radius: 20rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}
.main .card .card_content .logo{
  width: 70rpx;
  height: 70rpx;
  margin: 40rpx 30rpx;
}
.main .card .card_content .logo image{
  width: 70rpx;
  height: 70rpx;
}
.main .card .card_content .content{
  line-height: 60rpx;
}
.main .card .card_content .content .bank_title{
  width: 530rpx;
  font-size: 34rpx;
  color: rgb(51,51,51);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.main .card .card_content .content .name_account{
  width: 530rpx;
  font-size: 28rpx;
  color: rgb(102,102,102);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.main .btn{
  width: 590rpx;
  height: 94rpx;
  background:#F89417;
  border-radius: 10rpx;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  margin-top: 90rpx;
}
.icontianxie{
  font-size: 40rpx;
  text-align: right;
}