/* pages/my/apply/index/index.wxss */
page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
  padding-top: 20rpx;
}
.main .review{
  width: 750rpx;
  height: 100%;
  margin-bottom: 100rpx;
}
.main .review .review_content{  
  width: 750rpx;
  height: 100%;
  margin-bottom: 20rpx;
  background: #fff;
}
.main .review .review_content .order{
  width: 690rpx;
  height: 85rpx;
  border-bottom: 1rpx solid rgb(229,229,229);
  display: flex;
  font-size: 26rpx;
  color: rgb(136,136,136);
  margin: 0 auto;
  justify-content: space-between;
  align-items: center;
}
.main .review .review_content .order :nth-child(2){
  color: rgb(254,191,0);
}
.main .review .review_content .review_content_text{
  width: 690rpx;
  height: 100%;
  border-bottom: 1rpx solid rgb(229,229,229);
  margin: 0 auto;
  display: flex;
  /* align-items: center; */
}
.main .review .review_content .review_content_text .text{
  width: 100%;
  padding: 20rpx 0;
}
.main .review .review_content .review_content_text .text .title{
  font-size: 30rpx;
  color: rgb(51,51,51);  
  display: flex;
	height: 36rpx;
	text-align: left;

}
.main .review .review_content .review_content_text .text .title span{
	/* min-width: 500rpx; */
	height: 36rpx;
	overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;	
	text-align: left;
}
.main .review .review_content .review_content_text .text .title i{
	min-width: 110rpx;
	height: 36rpx;
	line-height: 42rpx;
  color: rgb(58,200,253);
  font-size: 26rpx;
  border: 1rpx solid rgb(58,200,253);
  border-radius: 5rpx;
  display: flex;
  align-items: center;
  justify-content: center;
	text-align: left;
	margin-left: 10rpx;
}
.main .review .review_content .review_content_text .text .date{
  font-size: 28rpx;
  color: rgb(102,102,102);
  display: flex;
  margin-top: 15rpx;
}
.main .review .review_content .review_content_text .text .date :nth-child(2){
  margin-left: 80rpx;
}
.main .review .opn{
  width: 690rpx;
  display: flex;
  justify-content: space-between;
  margin: 0 auto;
}
.main .review .opn .btn{
  width: 690rpx;
  display: flex;
  padding: 30rpx 0;
  justify-content: flex-end;
}
.main .review .opn .btn .btn1{
  width: 190rpx;
  height: 50rpx;
  border-radius: 25rpx;
  border: 1rpx solid rgb(204,204,204);
  color: rgb(136,136,136);
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.main .review .opn .btn .btn2{
  width: 190rpx;
  height: 50rpx;
  border-radius: 25rpx;
  border: 1rpx solid rgb(254,191,0);
  color: rgb(254,191,0);
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 40rpx;
}
.main .payment{
  width: 750rpx;
  height: 98rpx;
  position: fixed;
  bottom: 0;
  background: rgb(254,191,0);
  font-size: 32rpx;
  color: rgb(255,255,255);
  display: flex;
  justify-content: center;
  align-items: center;
}


/*弹窗*/
.show-btn {
  margin-top: 100rpx;
  color: #22cc22;
}

.modal-mask {
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
  background: #000;
  opacity: 0.5;
  overflow: hidden;
  z-index: 9000;
  color: #fff;
}

.modal-dialog {
  width: 540rpx;
  overflow: hidden;
  position: fixed;
  top: 50%;
  left: 0;
  z-index: 9999;
  background: #f9f9f9;
  margin: -180rpx 105rpx;
  border-radius: 36rpx;
}

.modal-title {
  padding-top: 50rpx;
  font-size: 36rpx;
  color: #030303;
  text-align: center;
}

.modal-content {
  padding: 50rpx 32rpx;
}

.modal-input {
  display: flex;
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 4rpx;
  font-size: 28rpx;
}


.input {
  width: 100%;
  height: 82rpx;
  font-size: 28rpx;
  line-height: 28rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  color: #333;
}

.input-holder {
  color: #666;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  flex-direction: row;
  height: 86rpx;
  border-top: 1px solid #dedede;
  font-size: 34rpx;
  line-height: 86rpx;
}

.btn-cancel {
  width: 50%;
  color: #666;
  text-align: center;
  border-right: 1px solid #dedede;
}

.btn-confirm {
  width: 50%;
  color: #ec5300;
  text-align: center;
}