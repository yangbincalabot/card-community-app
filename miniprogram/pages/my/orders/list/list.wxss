page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
}
.swiper-tab{
  width: 750rpx;
  height: 100rpx;
  text-align: center;     
  background: #fff;  
}
.tab{
  width: 690rpx;
  height: 100rpx;
  display: flex;
  flex-flow: row;
  justify-content: space-around;
   /* align-items: center; */
  color: rgb(53,53,53);
  font-size: 30rpx;
  text-align: center;  
}
.swiper-tab-item{
    width: 30%; 
    height: 100rpx;
    color:#353535;  
    display: flex;
    align-items: center;
    justify-content: center;
}
.active{
  border-radius: 3rpx;
  border-width:6rpx;
  border-bottom-style: solid;
  border-bottom-color:  rgb(255,227,0);
  overflow: hidden;           
}
.juzhong{
  margin: 0 auto;
}
.domain{
  background-color: #fff;
  height: 100%;
  margin:0 20rpx;
}
.show{
  display: block;
}
.hidden{
  display: none;
}
.order_content{
  width: 690rpx;
  height: 100%;
  margin: 0 auto;
}
.order_content .o_ct{
  width: 690rpx;
  /* height: 768rpx; */
  background: #fff;
  border-radius: 20rpx;
  margin-top: 30rpx;
}
.order_content .o_ct .title{
  display: flex;
  justify-content: space-between;   
  margin: 30rpx 20rpx; 
  padding-top: 30rpx;
}
.order_content .o_ct .title .time{
  font-size: 28rpx;
  color: rgb(51,51,51);
}
.order_content .o_ct .title .payment{
  font-size: 28rpx;
  color: rgb(254,191,0);
}
.order_content .o_ct .product .pro{
  width: 690rpx;
  height: 180rpx;
  margin: 0 auto;
  margin-top: 20rpx;
  display: flex;
  /* justify-content: center; */
  align-items: center;
  position: relative;
}
.order_content .o_ct .product .pro .imgs image{
  width: 180rpx;
  height: 140rpx;
  border-radius: 5rpx;
  margin: 20rpx 10rpx 20rpx 20rpx;
}
.order_content .o_ct .product .pro .text{
  margin: 20rpx 0;
}
.order_content .o_ct .product .pro .text .title{
	padding: 0;
	margin: 0 ;
  font-size: 30rpx;
  color: rgb(51,51,51);  
  overflow : hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.order_content .o_ct .product .pro .text .color{
	padding: 5rpx 10rpx;
  background: rgb(243,243,243);
  border-radius: 5rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgb(102,102,102);
  margin: 20rpx 0;
}
.order_content .o_ct .product .pro .text .price{
  font-size: 32rpx;
  color: rgb(255,25,25);
}
.order_content .o_ct .product .pro .size{
  font-size: 22rpx;
  color: rgb(136,136,136);
  position: absolute;
  bottom: 10rpx;
  right: 20rpx;
}
.main .service{
  margin: 40rpx 20rpx;
}
.main .service .s{
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}
.main .service .s .s1{
  font-size: 24rpx;
  color: rgb(51,51,51);
}
.main .service .s .s2{
  font-size: 28rpx;
  color: rgb(255,25,25);
  
}
.main .service .btn{
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-bottom: 30rpx;
}
.main .service .btn .btn1{
  width: 160rpx;
  height: 50rpx;
  border: 1rpx solid rgb(204,204,204);
  border-radius: 25rpx;
  font-size: 30rpx;
  color: rgb(136,136,136);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 30rpx;
}
.main .service .btn .btn2{
  width: 160rpx;
  height: 50rpx;
  border: 1rpx solid rgb(254,191,0);
  border-radius: 25rpx;
  font-size: 30rpx;
  color: rgb(254,191,0);
  display: flex;
  justify-content: center;
  align-items: center;
}