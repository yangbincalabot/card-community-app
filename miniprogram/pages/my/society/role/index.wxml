<!--pages/my/society/role/index.wxml-->
<!--pages/my/management/management.wxml-->
<view class="main">
  <block wx:for="{{ list }}" wx:key="index">
    <view class="box_view">
      <view class="box">
        <view class="name">
          {{ item.name }}
        </view>
        <view class="btn">
          <block wx:if="{{ index > 0 }}">
            <button class="btn1" hover-class="none" bindtap="moveUp" data-id="{{ item.id }}" data-to_id="{{ list[index-1] ?list[index-1].id:'' }}">上移</button>
            <button class="btn2" hover-class="none" bindtap="topUp" data-id="{{ item.id }}">置顶</button>
          </block>
          <button class="btn3" hover-class="none" bindtap="navigateToUrl"  data-url="/pages/my/society/assort/index?id={{item.id}}&aid={{aid}}">编辑</button>
          <button class="btn4" hover-class="none" bindtap="setFee" data-show="{{ true }}" data-id="{{ item.id }}">费用</button>
        </view>
      </view>
    </view> 
  </block>


  <view class="add" bindtap="addRole">新增角色</view>
  <!-- 新增角色开始 -->
  <view class="showModal" wx:if="{{showModal}}">
    <view class="showModal_box">
      <view class="title">新增角色</view>
      <input placeholder="请输入角色名" bindblur="inputValue" value="{{ intValue }}" data-type="name" />
      <!-- <input placeholder="请输入角色价格" bindblur="inputValue" data-type="fee" value="{{ fee }}" type="digit" /> -->
      <view class="showModal_btn">
        
        <button class="cancel" bindtap="cancel">取消</button>
        <button class="confirm" bindtap="confirm">确定</button>
      </view>
    </view>
  </view>
<!-- 新增角色介绍 -->


  <!-- 设置角色价格开始 -->
  <view class="showModal" wx:if="{{showFeeModal}}">
    <view class="showModal_box">
      <view class="title">角色费用</view>
      <input placeholder="请输入角色费用" bindblur="inputValue" data-type="fee" value="{{ fee }}" type="digit" />
      <view class="showModal_btn">
        <button class="cancel" bindtap="setFee" data-show="{{ false }}">取消</button>
        <button class="confirm" bindtap="setFeeComfile">确定</button>
      </view>
    </view>
  </view>
  <!-- 设置角色价格结束 -->
</view>






