<view class="main">
    <form bindsubmit="formSubmit">
        <view class="ct_view">
            <view class="ct" bindtap="UploadImage" data-type="image">
                <view class="ct_left">
                    <text>封面</text>
                </view>
                <view class="ct_right">
                    <image src="{{ image_url }}"></image>
                    <span class="icon iconfont iconyoujiantou"></span>
                </view>
            </view>
            <view class="ct">
                <view class="ct_left">
                    <text><text class="required">*</text>名称</text>
                    <input placeholder="请输入协会名称" placeholder-class="placeholder" name="name" value="{{ formData.name }}"></input>
                </view>
            </view>
            <view class="ct" wx:if="{{ user_id != 0 }}">
				<view class="ct_left">
					<text><text class="required">*</text>上级</text>
				</view>
				<view class="ct_right picker-right" >
					<picker bindchange="bindPickerChange" value="{{currentIndex}}" range="{{associations}}" range-key="name">
						<view class="picker">
							{{ currentTitle }}
						</view>
                        <span class="icon iconfont iconyoujiantou"></span>
					</picker>
					
				</view>
			</view>
            <!-- <view class="ct" wx:if="{{ formData.user_id > 0 }}">
                <view class="ct_left">
                    <text><text class="required">*</text>费用</text>
                    <input placeholder="请输入加入协会费用" placeholder-class="placeholder" type="digit" name="fee" value="{{ formData.fee }}"></input>
                </view>
            </view> -->
        </view>
        <!-- 协会简介开始 -->
        <view class="ct_view">
            <view class="ct address">
                <view class="ct_left">
                    <text>协会简介</text>
                    <textarea placeholder="请填写协会简介" placeholder-class="placeholder" name="desc" value="{{ formData.desc }}"></textarea>
                </view>
                <view class="ct_right">
                    <span class=""></span>
                </view>
            </view>
        </view>
        <view class="ct_view">
            <view class="ct address">
                <view class="ct_left">
                    <text>简介相册</text>
                </view>
            </view>
            <view>
                <view class="img">
                    <view class="img_box">
                        <block wx:if="{{ formData.images.length < 9 }}">
                            <span bindtap="UploadImage" data-type="images">
                                <image src='https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/update.png'></image>
                            </span>
                        </block>
                        <block wx:for="{{ formData.images }}" wx:key="index">
                            <span>
                                <image src='{{ item }}'></image>
                                <i class="icon iconfont iconshanchu1" data-index="{{ index }}" data-type='images' bindtap="deleteImage"></i>
                            </span>
                        </block>
                    </view>
                </view>
            </view>
        </view>

        <!-- 协会简介结束 -->


        <!-- 服务简介开始 -->
        <view class="ct_view">
            <view class="ct address">
                <view class="ct_left">
                    <text>服务简介</text>
                    <textarea placeholder="请填写服务简介" placeholder-class="placeholder" name="service_desc" value="{{ formData.service_desc }}"></textarea>
                </view>
                <view class="ct_right">
                    <span class=""></span>
                </view>
            </view>
        </view>
        <view class="ct_view">
            <view class="ct address">
                <view class="ct_left">
                    <text>服务相册</text>
                </view>
            </view>
            <view>
                <view class="img">
                    <view class="img_box">
                        <block wx:if="{{ formData.service_images.length < 9 }}">
                            <span bindtap="UploadImage" data-type="service_images">
                                <image src='https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/update.png'></image>
                            </span>
                        </block>
                        <block wx:for="{{ formData.service_images }}" wx:key="index">
                            <span>
                                <image src='{{ item }}'></image>
                                <i class="icon iconfont iconshanchu1" data-index="{{ index }}" data-type='service_images' bindtap="deleteImage"></i>
                            </span>
                        </block>
                    </view>
                </view>
            </view>
        </view>

        <!-- 服务简介结束 -->


        <!-- 会员墙开始 -->

        <view class="ct_view">
            <view class="ct address">
                <view class="ct_left">
                    <text>会员墙</text>
                </view>
            </view>
            <view>
                <view class="img">
                    <view class="img_box">
                        <block wx:if="{{ formData.member_wall.length < 9 }}">
                            <span bindtap="UploadImage" data-type="member_wall">
                                <image src='https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/update.png'></image>
                            </span>
                        </block>
                        <block wx:for="{{ formData.member_wall }}" wx:key="index">
                            <span>
                                <image src='{{ item }}'></image>
                                <i class="icon iconfont iconshanchu1" data-index="{{ index }}" data-type="member_wall" bindtap="deleteImage"></i>
                            </span>
                        </block>
                    </view>
                </view>
            </view>
        </view>

        <!-- 会员墙结束  -->


        <!-- 联系方式开始 -->

        <view class="ct_view">
            <view class="ct address">
                <view class="ct_left">
                    <text>联系方式</text>
                    <textarea placeholder="请填写联系方式" placeholder-class="placeholder" name="contact_us" value="{{ formData.contact_us }}"></textarea>
                </view>
                <view class="ct_right">
                    <span class=""></span>
                </view>
            </view>
        </view>


        <!-- 联系方式结束 -->

        <!-- 入会须知开始 -->

        <view class="ct_view">
            <view class="ct address">
                <view class="ct_left">
                    <text>入会须知</text>
                    <textarea placeholder="请填写入会须知" placeholder-class="placeholder" name="instructions" value="{{ formData.instructions }}"></textarea>
                </view>
                <view class="ct_right">
                    <span class=""></span>
                </view>
            </view>
        </view>


        <!-- 入会须知结束 -->


        <view style="height: 90rpx"></view>
        <cover-view class="coverBtn">
            <button form-type="submit">保存</button>
        </cover-view>
    </form>
</view>