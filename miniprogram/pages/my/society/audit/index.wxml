<!--pages/my/society/audit/index.wxml-->
<view class="main">
    <view class="show">
        <view class="time">
            <block wx:for="{{ list }}" wx:key="index">
                <view class="user">
                    <view class="user_ct">
                        <view class="user_img" bindtap="navigatorToUrl">
                            <view class="user_image">
                                <image src="{{ item.image }}"></image>
                            </view>
                            <view class="user_name">
                                <view class="name">{{ item.name }}</view>
                                <!-- <view class="add_time">{{ item.user.company_card ? item.user.company_card.industry_name : '行业未设置' }}</view>
                                <view class="add_time">{{ item.created_at }}</view> -->
                            </view>
                        </view>
                        <view class="add_user" wx:if="{{ item.pat === 1 }}">已通过</view>
                        <view class="add_user" wx:elif="{{ item.pat === 3 }}">未通过</view>
                        <view class="add_user accept" wx:if="{{ item.pat === 2 }}" bindtap="verify" data-id="{{ item.id }}" >审核</view>
                    </view>
                </view>
            </block>
        </view>
    </view>
</view>
