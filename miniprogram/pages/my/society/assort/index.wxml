<!--pages/my/society/assort/index.wxml-->
<view class="main">
  <view class='page_row' >
      <view class="search">
          <view class="df search_arr" style="border-radius:5rpx">
              <input class="saveInput" bindinput="inputValue"  placeholder="公司名" value="{{ intValue }}" placeholder-style='font-size:28rpx;color:#999999;text-align:left'></input>
          </view>
      </view>
      <view class='save' bindtap="roleSave">保存</view>
  </view>
  <view class='page_row' >
      <view class="search">
          <view class="df search_arr">
              <input class="" placeholder="请输入公司名" value="{{ keyword }}" bindconfirm="searchValue" 
               bindinput="changeSearch" placeholder-style='font-size:28rpx;color:rgb(178,178,178);text-align:center'></input>
          </view>
      </view>
      <view class='sousuo' bindtap="searchValue">搜索</view>
  </view>

  <block wx:for="{{ companyList }}" wx:key="index">
    <view class="box_view">
      <view class="box">
        <view class="name">
        {{ item.company_name }}
        </view>
        <view class="box_content">
          <image src="{{ item.user.carte.avatar?item.user.carte.avatar:'' }}"></image>
          <view class="ct_text">
            <view class="ct_post">{{ item.user.carte.position?item.user.carte.position:'' }}</view>
            <view class="tel">{{ item.user.carte.name?item.user.carte.name:'' }} <span wx:if="{{ item.user.carte.phone }}">{{ item.user.carte.phone?item.user.carte.phone:'' }}</span></view>
          </view>
        </view>
        <view class="btn">
          <block wx:if="{{ index > 0 }}">
            <button class="btn1" hover-class="none" bindtap="moveUp"  data-id="{{ item.id }}" data-to_id="{{ companyList[index-1] ?companyList[index-1].id:'' }}" data-index="{{ index }}">上移</button>
            <button class="btn2" hover-class="none" bindtap="topUp" data-id="{{ item.id }}" data-index="{{ index }}">置顶</button>
           </block>
          <button class="btn3" hover-class="none" bindtap="delCompany" data-cid="{{ item.id }}" data-index="{{ index }}">删除</button>
        </view>
      </view>
    </view>
  </block>

<block wx:for="{{ noList }}" wx:key="index">
  <view class="box_view">
    <view class="box add_box">
      <view class="name add_fireName">
      {{ item.company_name }}
        <view class="box_content add_content">
          <image src="{{ item.user.carte.avatar?item.user.carte.avatar:'' }}"></image>
          <view class="ct_text">
            <view class="ct_post">{{ item.user.carte.position?item.user.carte.position:'' }}</view>
            <view class="tel">{{ item.user.carte.name?item.user.carte.name:'' }} <span wx:if="{{ item.user.carte.phone }}">{{ item.user.carte.phone?item.user.carte.phone:'' }}</span></view>
          </view>
        </view>
      </view>
      <view class="btn" bindtap="addCompany" data-cid="{{ item.id }}">
        <image src="/images/addFire.png"></image>
      </view>
    </view>
  </view>
 </block>

</view>

