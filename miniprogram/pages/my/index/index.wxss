/* pages/mine/index.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.mine_bg{
  width: 100%;
  height: 395rpx;
  background: url(http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/bg_my.png) no-repeat;
  background-size: 100% 100%;
  padding-top: 12rpx;
}
.top_ct{
  width: 650rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  color: #ffffff;
  font-size: 24rpx;
  margin-top: 145rpx;
}
.top_ct .img{
  width: 138rpx;
  height: 138rpx;
}
.top_ct .img image{
  width: 138rpx;
  height: 138rpx;
  border-radius: 90rpx;
}
.ct_right{
  margin-left: 42rpx;
}
.ct_right text{
  font-size: 32rpx;
}
.ct_right i{
  margin: 0 16rpx;
}
.ct_right span{
  height: 38rpx;
  padding: 0 20rpx;
  background: #FFC163;
  border-radius: 20rpx;
  border: 2rpx solid #FFEC30;
}
.mine_content{
  width: 710rpx;
  margin: 0 auto;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-radius: 40rpx;
  margin-top: -90rpx;
  font-size: 24rpx;
  color: #000000;
  line-height: 40rpx;
  padding: 60rpx 0 40rpx 0;
  background: url(http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/bg_my_c.png) no-repeat;
  background-size: 100%;
}
.ct_box{
  text-align: center;
}
.mine_content .img{
  width: 50rpx;
  height: 50rpx;
  margin: 0 auto;
}
.mine_content .img image{
  width: 50rpx;
  height: 50rpx;
}
.mine_content .ct_box:first-of-type .img image{
  width: 66rpx;
  height: 50rpx;
}
.mine_content .ct_title{
  padding: 10rpx 0;
}
.mine_ct{
  width: 710rpx;
  margin: 20rpx auto;
  padding-top: 20rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  background: #ffffff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
  box-shadow: 0 2rpx 12rpx 0 rgba(0,0 ,0 ,0.2 );
  padding-bottom: 10rpx;
  position: relative;
}
.mine_ct .tip{
  position: absolute;
  height: 30rpx;
  width: 90rpx;
  /* background: #FFC163; */
  color: #fff;
  transform: rotate(45deg);
  right: -10rpx;
  top: 20rpx;
  text-align: center;
  z-index: 2;
  font-size: 20rpx;
  line-height: 30rpx;
}
.mine_ct .tipImg{
  position: absolute;
  right: -14rpx;
  top: 1rpx;
  z-index: 1;
  width: 100rpx;
  height: 100rpx;
}
.ct_view{
  margin: 14rpx 40rpx;
  text-align: center;
}
.mine_ct .img{
  width: 50rpx;
  height: 50rpx;
  margin: 0 auto;
}
.mine_ct .img image{
  width: 50rpx;
  height: 50rpx;
}
.mine_ct .ct_title{
  padding: 10rpx 0;
}
button{
  background: #ffffff;
  padding: 0;
  margin: 0;
  font-size: 24rpx;
  color: #666666;
  line-height: 36rpx;
}
.mine_top{
  position: fixed;
}
.zhanwei{
  width: 100%;
  opacity: 0;
}
.mine_top_btn{
  width: 180rpx;
  background-color: #0B0B0C;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  margin-left: 25rpx;
  justify-content: space-between;
  border:1rpx solid #494848;
}
.mine_top_btn image{
  height: 35rpx;
  width: 35rpx;
}
.mine_top_btn image:nth-of-type(1){
   margin-left: 25rpx;
}
.mine_top_btn image:nth-of-type(2){
  margin-right: 30rpx;
}
.mine_top_btn_span{
  border-right: 1rpx solid #181818;
  height: 30rpx;
}