/* pages/vip/index.wxss */
.main{
  width: 750rpx;
  height: 100%;
}
.main .header{
  width: 100%;
  height: 310rpx;
  background: url(https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/vip.png) no-repeat;
  background-size: 100%;
}
.main .vip_content{
  width: 100%;
  height: 100%;
  margin-bottom: 60rpx;
}
.main .vip_content .vip_ct{
  width: 100%;
  margin-top: 54rpx;
  /* height: 510rpx; */
}
.main .title{
  width: 680rpx;
  height: 30rpx;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;  
  padding: 30rpx 20rpx;
}
.main .title .left{
  display: flex;  
  font-size: 40rpx;
  color: rgb(51,51,51);
}
.main .title .left .l{
  width: 8rpx;
  height: 40rpx;
   background:  rgb(255,227,0);
   margin-right: 20rpx;
   margin-top: 6rpx;
}
.main .title .left i{
  margin-left: 30rpx;
}
.main .content{
  width: 667rpx;
  margin: 0 auto;
  font-size: 30rpx;
  margin-top: 30rpx;
}
.main .content .c1{
  color: rgb(51,51,51);
}
.main .content .c2{
  color: rgb(102,102,102);
  margin-top: 20rpx;
}