/* pages/card/setting/index.wxss */
page{
  background: #f5f5f5;
}
.list{
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 550;
  padding: 20rpx 40rpx;
  background: #fff;
}
.list .title{
  font-size: 32rpx;
}
.list .item{
  display: flex;
  align-items: center;
  justify-content: center
}
.item image{
  width: 50rpx;
  height: 50rpx;
  margin-right: 40rpx;
}
.item_r{
  display: flex;
  flex-direction: column;
  /* align-items: center; */
}
.item_r .cell{
  display: flex;
  align-items: center;
  margin-top: 30rpx;
}
.item_r .cell picker{
  height: 67rpx;
  width: 420rpx;
  line-height: 67rpx;
  border: 1rpx solid #e3e3e3;
  border-radius: 16rpx;
  text-align: left;
}
.item_r .text{
  padding: 0 30rpx;
  font-weight: 500;
}
.item_r .switch_box{
  width: 166rpx;
  height: 50rpx;
  border-radius:28rpx;
  background: #6db3f9;
  position: relative;
  color: #fff;
  line-height: 50rpx;
  text-align: right;
  padding:0 20rpx;
  box-sizing: border-box;
}
.switch_box image{
  width: 51rpx;
  height: 51rpx;
  border-radius: 50%;
  position: absolute;
  margin: 0;
  left: 4rpx;
  transition: left 0.2s;
  box-shadow: 0 2rpx 12rpx 0 rgba(0,0,0,0.5);
}
.switch_box.weirz{
  background: #c6c6c6;
  text-align: left;
}
.switch_box.weirz image{
  left: 110rpx;
}

.btn{
    width: 590rpx;
    height: 94rpx;
    background: rgb(254,191,0);
    border-radius: 10rpx;
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 auto;
    margin-top: 10rpx;
    margin-bottom: 10rpx;
}