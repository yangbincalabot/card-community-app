/* pages/card/setting_two/index.wxss */
page{
  background: #f5f5f5;
}
.container{
  font-size: 30rpx;
  color: rgba(51, 51, 51, 1);
  font-weight: 500;
}
.box{
  padding: 30rpx;
  box-sizing: border-box;
  background: #fff;
  margin-bottom: 20rpx;
}
.list{
  display: flex;
  flex-wrap: wrap;
}
.list .item{
  position: relative;
  border-radius: 50rpx;
  border: 1px solid #e3e3e3;
  padding: 6rpx 30rpx;
  margin-right: 30rpx;
  margin-top: 30rpx;
  font-size: 30rpx;
}
.list .item .closeImg{
  position: absolute;
  right: -15rpx;
  top: -15rpx;
  width: 40rpx;
  height: 40rpx;
}
.select{
  padding-bottom: 30rpx;
  box-sizing: border-box;
}
.select .title{
  font-size: 34rpx;
}
.resulte .title{
  padding-top: 20rpx;
  box-sizing: border-box;
  color: #666;
  font-size: 28rpx;
  border-top:1px solid  #D7D7D7;
}
.resulte .item{
  color: #50A6F9;
  border-color: #50A6F9;
}

.cityPup .mask{
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0,0, 0.34);
  z-index: 10;
}
.cityPup .content{
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  margin: auto;
  width: 600rpx;
  height: 520rpx;
  z-index: 20;
  background: #fff;
  border-radius: 12rpx;
  padding:0 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
.closePup{
  position: absolute;
  top: -80rpx;
  left: 0;
  right: 0;
  margin: auto;
  width: 66rpx;
  height: 66rpx;
}
.cityPup .title{
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 34rpx;
  height: 70rpx;
  border-bottom: 1px solid #e3e3e3;
  font-weight: 500;
}
.cityPup .selects{
  padding: 30rpx 0;
  display: flex;
  align-items: center;
}
.cityPup .selects view:first-of-type{
  margin-right: 10rpx;
  font-weight: 520;
}
.cityPup .selects view:last-of-type{
  border-radius: 18rpx;
  border: 1px solid #e3e3e3;
  padding: 6rpx 30rpx;
  font-size: 30rpx;
  min-width: 100rpx;
}
.cityPup .citys{
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  flex:1;
  align-content: flex-start;
  overflow-y: scroll;
}
.cityPup .citys .item{
   border-radius: 50rpx;
  border: 1px solid #e3e3e3;
  padding: 6rpx 30rpx;
  margin-right: 30rpx;
  margin-bottom: 30rpx;
  font-size: 30rpx;
}
.cityPup .btns{
  width: 100%;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.cityPup .btn{
  width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #fff;
  background: #50A6F9;
  border-radius: 40rpx;
}