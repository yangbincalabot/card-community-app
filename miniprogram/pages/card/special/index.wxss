/* pages/card/special/index.wxss */
.card_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
    display: flex;
}
.card_view{
    width: 690rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1rpx solid #eeeeee;
    padding: 18rpx 0;
    margin: 0 auto;
    position: relative;
}
.card{
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #878787;
}
.card image{
    width: 110rpx;
    height: 110rpx;
    border-radius: 90rpx;
}
.card_title{
    font-size: 32rpx;
    color: #000000;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.card_title span{
    font-size: 24rpx;
    color: #878787;
    margin-left: 34rpx;
    max-width: 270rpx;
    display: inline-block;
    line-height: 1.2em;
    overflow: hidden;/*超出部分隐藏*/
    white-space: nowrap;/*不换行*/
    text-overflow:ellipsis;/*超出部分文字以...显示*/
}
.card_text{
    margin-left: 24rpx;
    font-size: 24rpx;
    color: #878787;
    line-height: 50rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.icontel{
    /* margin-right: 64rpx;
    font-size: 54rpx; */
    margin-right: 26rpx;
    font-size: 48rpx;
    display: inline-block;
}
.nexticon{
  margin-right: 36rpx;
   font-size: 48rpx;
   display: inline-block;
}
.site span{
  margin-left: 20rpx;
}
.num{
  width: 690rpx;
  height: 100rpx;
  font-size: 30rpx;
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

movable-area {
  height: 190rpx;
  width: calc(100vw - 120rpx);
}
movable-view {
  height: 190rpx;
  width: 100vw;
  background: #fff;
  z-index: 30;
}

.delete-btn{
  background-color:red;
  color: #fff;
}
.delete-btn{
  width: 190rpx;
  height: 190rpx;
  line-height: 190rpx;
  text-align: center;
  font-size: 26rpx;
}