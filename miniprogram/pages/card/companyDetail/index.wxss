/* pages/my/company/company.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.ct_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
}
.ct{
  width: 710rpx;
  border-bottom: 1rpx solid #eeeeee;
  margin: 0 auto;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ct_left{
  display: flex;
  align-items: center;
}
.ct_left image{
  width: 104rpx;
  height: 104rpx;
  border-radius: 14rpx;
}
.text{
  width: 568rpx;
  margin-left: 18rpx;
  font-size: 28rpx;
  color: #A1A1A1;
  line-height: 50rpx;
}
.firm_ct{
  /* width: 500rpx; */
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
}
.text .firm{
  font-size: 32rpx;
  color: #2F2F2F;
}
.ct_right button{
  width:118rpx;
  height:56rpx;
  border-radius:14rpx;
  border:2rpx solid rgba(255,171,44,1);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  font-size: 28rpx;
  color: #FF9F0D;
}
.icontel{
  font-size: 54rpx;
  color: rgba(0, 0, 0, .5);
  margin-left: 58rpx;
}
.iconlocation{
  font-size: 40rpx;
  color: #A1A1A1;
}
.address{
  font-size: 28rpx;
  color: #A1A1A1;
}
.url{
  width: 100%;
  height: 100rpx;
  background: #ffffff;
  margin: 0 auto;
}
.url_box{
  width: 710rpx;
  height: 100rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  font-size: 32rpx;
  color: #333333;
}
.url_box span{
  margin-left: 62rpx;
  font-size: 32rpx;
  color: #333333;
}
.swiper-tab{
    width: 100%;
    text-align: center;
    height: 90rpx;
    line-height: 90rpx;
    display: flex;
    flex-flow: row;
    font-size: 30rpx;
    padding: 20rpx 0;
}
.swiper-tab-item{
    width: 25%; 
    color:#333333;
    margin-left: 30rpx;
}
.active{
  color:#50A6F9;
  border-bottom: 6rpx solid #50A6F9;
}
.show{
  display: block;
}
.hidden{
  display: none;
}
.content{
  width: 100%;
  display: flex;
  position: relative;
  background: #ffffff;
  margin: 20rpx auto;
  padding: 20rpx 0;
}
.ct_view{
  width: 100%;
}
.introduce{
  width: 100%;
  height: 100%;
  background: #ffffff;
}
.introduce_ct,.introduce_img{
  width: 710rpx;
  margin: 0 auto;
}
.introduce_ct{
  font-size: 28rpx;
  color: #333333;
  padding: 16rpx 0;
  text-indent: 2em;
  line-height: 50rpx;
}
.introduce_img image{
  width: 710rpx;
}
.supply_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
  margin: 0 auto;
}
.supply{
  width: 710rpx;
  border-bottom: 1rpx solid #eeeeee;
  margin: 0 auto;
  padding: 30rpx 0;
  display: flex;
}
.supply image{
  width: 112rpx;
  height: 112rpx;
  border-radius: 90rpx;
}
.supply_right{
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #000000;
}
.supply_name{
  font-size: 36rpx;
}
.supply_name span{
  height:42rpx;
  background:linear-gradient(180deg,rgba(69,153,241,1) 0%,rgba(3,120,242,1) 100%);
  border-radius:14rpx;
  padding: 5rpx 20rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  margin-left: 20rpx;
}
.supply_msg{
  margin: 20rpx auto;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  font-size: 24rpx;
  color: #939393;
}
.supply_text{
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.supply_trivia{
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 56rpx;
  font-size: 24rpx;
  color: #939393;
}
.supply_btn{
  display: flex;
  align-items: center;
  margin-left: 50rpx;
}
.supply_btn1,.supply_btn2{
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
}
.supply_btn1{
  border-radius:14rpx;
  border:2rpx solid rgba(255,147,0,1);
  background: #ffffff;
  font-size: 24rpx;
  color: #FF9300;
}
.supply_btn2{
  font-size: 24rpx;
  color: #FFFFFF;
  background:linear-gradient(180deg,rgba(117,117,117,1) 0%,rgba(0,0,0,1) 100%);
  border-radius:14rpx;
  margin-left: 20rpx;
}
.icondianzan{
  margin-right: 10rpx;
}
.supply_imgs{
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin: 28rpx auto;
}
.supply_imgs image{
  width: 180rpx;
  height: 180rpx;
  border-radius: 0;
  margin : 0 12rpx 12rpx 0;
}