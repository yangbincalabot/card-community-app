  width: 180rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  background-color: #fff;
  border-radius: 20px;
  color: #50a6f9;
  border: 1px solid #50a6f9;
}

.weui-dialog__ft .btnBox .btnmy:last-of-type{
  background: #50a6f9;
  margin-left: 50rpx;
  color: #fff;
}
