/* 弹框 */
.weui-dialog{
  background-color: #fff;
  text-align: center;
  border-radius: 12px;
  overflow: hidden;
  display: -webkit-box;
  display: -webkit-flex;
  display: flex;
  -webkit-flex-direction: column;
  -webkit-box-orient: vertical;
  -webkit-box-direction: normal;
  flex-direction: column;
  max-height: 90%;
}

.weui-dialog__bd{
  -webkit-box-flex: 1;
  -webkit-flex: 1;
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 24px;
  margin-bottom: 32px;
  min-height: 40px;
  font-size: 17px;
  line-height: 1.4;
  overflow-wrap: break-word;
  -webkit-hyphens: auto;
  hyphens: auto;
  color: rgba(0,0,0,.5);
}
.weui-demo-dialog {
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.weui-demo-dialog_show {
  visibility: visible;
  opacity: 1;
}

.weui-dialog__wrp{
  transition:all .3s;
  transform:translateY(100%);
}

.weui-demo-dialog_show .weui-dialog__wrp{
    transform:translateY(0);
}
.weui-dialog{
  border-radius: 8rpx;
  position: relative;
}
.dialog_colseImg{
  width: 54rpx;
  height: 54rpx;
  margin-left: 240px;
  margin-bottom: 50px;
}
.weui-dialog__bd {
  padding: 0;
}

.weui-dialog__bd:first-child {
  padding: 0;
}

.weui-dialog__bd image {
  width: 632rpx;
  height: 328rpx;
}

.weui-dialog__ft .btn_r {
  width: 550rpx;
  height: 88rpx;
  margin: 55rpx auto 60rpx auto;
}

.weui-dialog__bd .bd_text {
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(20, 20, 20, 1);
  margin-top: 45rpx;
}

.weui-dialog__bd{
  flex-direction: column;
  margin-bottom: 0;
  width: 100%;
}

.weui-mask{
  position: fixed;
  z-index: 1000;
  top: 0;
  right: 0;
  left: 0;
  bottom: 0;
  background: rgba(0,0,0,.6);
}
.weui-dialog__wrp{
  flex-direction: column;
  position: fixed;
  z-index: 5000;
  bottom: 102rpx;
  left: 0;
  right: 0;
  max-height: 80%;
  text-align: center;
  font-size: 0;
  display: -webkit-box;
  display: -webkit-flex;
  display: flex;
  -webkit-box-align: center;
  -webkit-align-items: center;
  align-items: center;
  -webkit-box-pack: center;
  -webkit-justify-content: center;
  justify-content: center;
  background: #fff;
  border-radius: 6px 6px 0 0;
  /* box-shadow: 0 2px 12px 0 rgba(0,0,0,.5) */
}
.weui-dialog__wrp .weui-dialog__hd{
  font-size: 13px;
  color: #999;
  padding: 16rpx 0 28rpx 0;
  box-sizing: border-box;
  width: 100%;
  text-align: cneter;
  border-bottom: 1px solid #eeeeee;
}
.weui-dialog__wrp .weui-dialog__ft{
  font-size: 16px;
  color: #fff;
  box-sizing: border-box;
  padding: 20rpx;
  width: 100%;
}
.weui-dialog__ft .btnBox{
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
}
