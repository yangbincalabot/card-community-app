<!--pages/card/myCard/index.wxml-->
<view hidden="{{ isHidden }}" class='container {{card_color==2?"swiper-item-white":""}}'>
  <view class="{{scrollFlag?'show':''}} 'headFix'">
    <view class="imgBox">
      <image src="{{ cardDetail.avatar }}"></image>
    </view>
    <view class="desc">
      <view>{{ cardDetail.name }}</view>
      <view>{{ cardDetail.company_name }}</view>
    </view>
    <button class="btn" open-type="share">发名片</button>
  </view>
  <block wx:if="{{companyNav&&cardDetail.cid}}">
    <view class="footer_select">
      <view class="select_ct">
        <view class="icon iconfont iconshangcheng"></view>
        <view>商城</view>
      </view>
      <view class="select_ct" bindtap="navigatorToUrl" data-url="/pages/card/companyDetail/index?id={{ cardDetail.cid }}&tab=1">
        <view class="icon iconfont iconfabuxuqiu"></view>
        <view>供需</view>
      </view>
      <view class="select_ct" bindtap="navigatorToUrl" data-url="/pages/card/companyDetail/index?id={{ cardDetail.cid }}" hover-class="none">
        <view class="icon iconfont iconguanwang"></view>
        <view>官网</view>
      </view>
    </view>
  </block>
  <view class="footer" hidden="{{ footHide }}">
    <block wx:if="{{!cardDialog}}">
      <view class="footer_box" catchtap="dialogChange" data-url="../received/index?type=1">
        收到的名片
        <view class="imgs">
          <block wx:for="{{ offlineBusinessCard }}" wx:key="index">
            <image src="{{ item.avatar }}"></image>
          </block>
        </view>
        {{ offlineBusinessCard.length }}位
        <image class="jiantou" src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E7%AE%AD%E5%A4%B4%20%E4%B8%8B.png"></image>
      </view>
    </block>
    <block wx:else>
      <view class="footer_box">
        <view class="text" style="color:#999;flex:1;text-align:center;" bindtap="navigatorToUrl" data-url="/pages/card/index/index">去名片夹查看</view>
        <image catchtap="dialogChange" class="jiantou" style="padding:12rpx;" src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E7%AE%AD%E5%A4%B4%20%E4%B8%8A.png"></image>
      </view>
    </block>
  </view>
  <view class="top_box" wx:if="{{top_box}}">
    <block wx:for="{{topList}}" wx:key="item">
      <view class="item">
        <view>{{item.title}}</view>
        <view>{{item.number ? item.number:0 }}</view>
        <view>周+{{item.weekNumber ?item.weekNumber:0 }}</view>
      </view>
    </block>
  </view>
  <view style="position:absolute;" class="{{topBoxShow?'topBoxShowclass':''}} con-wrap" wx:key="{{item._id}}">
    <view class='card-box' data-index="{{index}}" style="min-height:{{windowHeight}}px">
      <swiper vertical="true" bindchange="bindchangeY" style="min-height:{{windowHeight}}px">
        <swiper-item class='{{card_color==2?"swiper-item-white":""}}'>
          <swiper style="min-height:{{windowHeight}}px" bindchange="bindchangeX">
            <swiper-item class='{{card_color==2?"swiper-item-white":""}}'>
              <!-- <scroll-view scroll-y="true" bindscroll="scroll" scroll-top="{{scrollTop}}" style="height:{{windowHeight}}px;overflow-anchor:none;"> -->

              <view class=" main m_top_box" bindtouchstart="touchstart" bindtouchmove="touchmove">
                <view style="min-height:{{windowHeight}}px;position:relative;">
                  <view class="userCard">
                    <view class="card_bg">
                      <view class="card_ct">
                        <view class="ct1">{{ cardDetail.company_name }}</view>
                        <view class="ct2">{{ cardDetail.name }}
                          <span>{{ cardDetail.position ?cardDetail.position:'未设置' }}</span>
                        </view>
                        <view class="ct3">
                          <image src="/images/user_icon1.png"></image>
                          <text>{{ cardDetail.phone ? cardDetail.phone : '未设置' }}</text>
                        </view>
                        <view class="ct3" bindtap="clipboard" data-value="{{ cardDetail.email ?  cardDetail.email : '' }}">
                          <image src="/images/user_icon3.png"></image>
                          <text>{{ cardDetail.email ?cardDetail.email:'未设置' }}</text>
                        </view>
                        <view class="ct3">
                          <image src="/images/user_icon2.png"></image>
                          <text>{{ cardDetail.company_card.address_title
                                            ?cardDetail.company_card.address_title:(cardDetail.address_title ?
                                            cardDetail.address_title : '未设置') }}</text>
                        </view>
                      </view>
                    </view>
                  </view>
                  <view class="user_code" hidden="{{ footHide }}">
                    <view class="shareBox">
                      <!-- <image src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E8%BD%AC%E5%8F%91%E5%90%8D%E7%89%87.png"></image> -->
                      <block wx:if="{{ footHide }}">
                        <button hover-class="none" wx:if="{{ is_send === false}}" bindtap="sendCard">发名片
                        </button>
                        <button hover-class="none" class="success" wx:else>已递名片</button>
                      </block>
                      <block wx:else>
                        <button hover-class="none" open-type="share">发名片</button>
                      </block>

                    </view>
                    <view>
                      <block wx:if="{{ !footHide }}">
                        <image src="{{ cardDetail.user.qrcode }}" data-type="reset"></image>
                      </block>
                      <block wx:else>
                        <image src="{{ cardDetail.user.qrcode }}"></image>
                      </block>

                    </view>
                    <view>扫一扫上面二维码，收藏我的名片</view>
                    <!-- <block wx:if="{{ footHide }}">
                        <button hover-class="none" wx:if="{{ is_send === false}}" bindtap="sendCard">发名片
                        </button>
                        <button hover-class="none" wx:else>已递名片</button>
                      </block>

                      <block wx:else>
                        <button hover-class="none" open-type="share">发名片</button>
                      </block> -->

                  </view>
                  <!-- <view class="footer" hidden="{{ footHide }}">
                      <view class="footer_box" catchtap="dialogChange" data-url="../received/index?type=1">
                        收到的名片
                        <view class="imgs">
                          <block wx:for="{{ offlineBusinessCard }}" wx:key="index">
                            <image src="{{ item.avatar }}"></image>
                          </block>
                        </view>
                        {{ offlineBusinessCard.length }}位
                        <image class="jiantou" wx:if="{{cardDialog}}" src="https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E7%AE%AD%E5%A4%B4%20%E4%B8%8A.png"></image>
                        <image class="jiantou" wx:else src="https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E7%AE%AD%E5%A4%B4%20%E4%B8%8B.png"></image>
                      </view>
                    </view> -->
                </view>
              </view>
              <!-- </scroll-view> -->

            </swiper-item>
            <swiper-item class='{{card_color==2?"swiper-item-white":""}}'>
              <view class="main">
                <view>
                  <view style="display:flex;justify-content:center;">
                    <view class="createMy right_item" bindtap="navigatorToUrl" data-url="/pages/my/card/editCard/index">
                      <image src="https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E5%88%9B%E5%BB%BAv%403x.png"></image>
                      编辑我的名片
                    </view>
                    <view class="addOthers right_item" bindtap="navigatorToUrl" data-url="/pages/card/create/index">
                      <image src="https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E6%B7%BB%E5%8A%A0%403x.png"></image>
                      添加他人的名片
                    </view>

                  </view>

                  <!-- <view class="text_huo">或</view> -->
                  <view class="OCRscan right_item" bindtap="navigatorToUrl" data-url="/pages/card/camera/index">
                    <image src="https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E6%89%AB%E6%8F%8F.png"></image>
                    OCR扫描纸质名片
                  </view>

                </view>
              </view>
            </swiper-item>
          </swiper>
        </swiper-item>
        <swiper-item class='{{card_color==2?"swiper-item-white":""}}' wx:if="{{showBlock2}}">

          <scroll-view scroll-y="true" bindscroll="scroll2" style="height:{{windowHeight}}px">
            <view class="main {{card_color==2?'swiper-item-white':''}}" style="background:#000000">
              <view>

                <view class="card">
                  <view class="card_box">
                    <view class="card_text">
                      <image src="/images/mycode.png"></image>
                    </view>
                  </view>
                  <view class="card_view">
                    <view class="access">
                      <view class="num">
                        <span class="icon iconfont icondianzanliang"></span>{{ cardDetail.visits }}
                      </view>
                      <view>访问量</view>
                    </view>
                    <view class="msg">
                      <view class="msg_box">
                        <view class="msg_left">
                          <image src="{{ cardDetail.avatar }}"></image>
                        </view>
                        <view class="msg_right">
                          <view>
                            <view class="name">{{ cardDetail.name }}
                              <span>{{ cardDetail.position ? cardDetail.position:'未设置'}}</span>
                            </view>
                            <view>{{ cardDetail.company_name }}</view>
                          </view>
                        </view>
                      </view>
                      <button class="msg_view" hover-class="msg_bg" bindtap="clipboard" data-value="{{ cardDetail.phone ?  cardDetail.phone : '' }}">
                        <image src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E7%94%B5%E8%AF%9D.png"></image>
                        <view class="msg_text">
                          <view class="msg_ct">
                            {{ cardDetail.phone ? cardDetail.phone : '未设置' }}
                          </view>
                        </view>
                      </button>
                      <button class="msg_view" hover-class="msg_bg" bindtap="clipboard" data-value="{{ cardDetail.wechat ?  cardDetail.wechat : '' }}">
                        <image src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E5%BE%AE%E4%BF%A1.png"></image>
                        <view class="msg_text">
                          <view class="msg_ct">{{ cardDetail.wechat ? cardDetail.wechat: '未设置' }}
                          </view>
                        </view>
                      </button>
                      <button class="msg_view" hover-class="msg_bg" bindtap="clipboard" data-value="{{ cardDetail.email ?  cardDetail.email : '' }}">
                        <image src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E9%82%AE%E7%AE%B1.png"></image>
                        <view class="msg_text">
                          <view class="msg_ct">{{ cardDetail.email ? cardDetail.email: '未设置' }}
                          </view>
                        </view>
                      </button>
                      <button class="msg_view" bindtap="openMap" hover-class="msg_bg">
                        <image src="http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/%E5%9C%B0%E5%9D%80.png"></image>
                        <view class="msg_text">
                          <view class="msg_ct">{{ cardDetail.company_card.address_title ?cardDetail.company_card.address_title:(cardDetail.address_title ? cardDetail.address_title : '未设置') }}
                          </view>
                        </view>
                      </button>
                    </view>
                    <view class="btnAll" wx:if="{{ !footHide }}">
                      <button class="btn1" bindtap="navigatorToUrl" data-url="../../my/card/editCard/index">编辑名片
                      </button>
                      <button class="btn2" open-type="share">分享名片</button>
                    </view>
                    <view class="btnAll" wx:else>
                      <block wx:if="{{ is_send === false }}">
                        <button class="btn1" bindtap="sendCard">发名片</button>
                      </block>
                      <block wx:else>
                        <button class="btn1">已递名片</button>
                      </block>
                      <button class="btn2" open-type="share">分享此名片</button>
                    </view>
                  </view>
                </view>
                <view class="title edit_title">
                  <view style="display:flex;align-items: center;">
                    <view class="title_left"></view>
                    个人介绍
                  </view>
                  <!-- <view class="edit">
                <span class="icon iconfont iconbianji1"></span>
                编辑
              </view> -->
                </view>
                <view class="introduce {{card_color=='1'?'introduce-white':''}}">
                  {{ cardDetail.introduction ? cardDetail.introduction: '未填写' }}
                </view>

                <!-- <view style="backgroud:red;width:100%;height:400px;"></view> -->

                <view class="title edit_title">
                  <view style="display:flex;align-items: center;">
                    <view class="title_left"></view>
                    相册
                  </view>
                  <!-- <view class="edit">
                <span class="icon iconfont iconshangchuan"></span>
                上传更多
              </view> -->
                </view>
                <view class="imgs">
                  <block wx:for="{{ cardDetail.images }}" wx:key="item">
                    <image src="{{ item }}" bindtap="previewImages" data-src="{{item}}" data-index="{{index}}"></image>
                  </block>
                </view>

                <view style="height:300rpx;width:100%;background:#000000;" class='{{card_color==2?"swiper-item-white":""}}'></view>
              </view>
            </view>
          </scroll-view>
        </swiper-item>
      </swiper>
    </view>
  </view>
  <!-- 收到的名片 弹框 -->
  <view class="weui-demo-dialog {{cardDialog ? 'weui-demo-dialog_show' : ''}}">
    <!-- <view class="weui-mask" bindtap="closeDialog"></view> -->
    <view class="weui-dialog__wrp">
      <view class="weui-dialog__hd">
        三天内收到{{ threeDaysReceiveCard.length }}条
      </view>
      <view class="weui-dialog__bd">
        <scroll-view class="scrollView" scroll-y="true">
          <view class="list">
            <block wx:for="{{ threeDaysReceiveCard }}" wx:key="index">
              <view class="list_item">
                <my-rate class="myrate" bindmarkChange="markChange" value_select="{{ item.stars }}" data-cid="{{ item.from_user.carte.id }}" data-fid="{{ item.from_user_id }}"></my-rate>
                <view class="imgBox">
                  <image src="{{ item.from_user.carte.avatar ? item.from_user.carte.avatar : item.from_user.avatar }}"></image>
                </view>
                <view class="right">
                  <view class="cardname overfl">{{ item.from_user.carte.name ? item.from_user.carte.name : (item.from_user.nickname ?item.from_user.nickname: item.from_user.phone ) }}
                    <block wx:if="{{ item.from_user.carte.position }}">
                      <span class="line"></span>
                      <span>{{ item.from_user.carte.position }}</span>
                    </block>
                  </view>
                  <view class="compy overfl">{{ item.from_user.carte.company_name }}</view>
                  <block wx:if="{{ isEditStatus === true }}">
                    <input class="input_bottom" value="{{ threeDaysReceiveCardTags[index].title }}" bindinput="changeTag" data-index="{{ index }}"></input>
                  </block>
                  <block wx:else>
                    <view>{{ threeDaysReceiveCardTags[index].title ? threeDaysReceiveCardTags[index].title : '未设置' }}</view>
                  </block>
                </view>
              </view>
            </block>
          </view>
        </scroll-view>
      </view>
      <view class="weui-dialog__ft">
        <view class="btnBox" wx:if="{{ threeDaysReceiveCard.length > 0 }}">
          <view class="btnmy" bindtap="changeEditStatus">编辑</view>
          <view class="btnmy" bindtap="postChange">确定</view>
        </view>
        <!-- <view class="text" bindtap="navigatorToUrl" data-url="/pages/card/index/index">去名片夹查看</view> -->
      </view>
    </view>
  </view>
</view>