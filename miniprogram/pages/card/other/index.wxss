/* pages/card/other/index.wxss */
@import '../myCard/index.wxss';
.card_box{
  height: 258rpx;
}
page{
  background: #252525;
}
.bounced{
    width: 100%;
    height: 100%;
    position: fixed;
    top: 0 ;
    left: 0;
    bottom: 0;
    right: 0;
    background: rgba(0, 0,0,.5);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
}
.pop_box{
    width: 500rpx;
    height: 400rpx;
    background: #ffffff;
    border-radius: 12rpx;
    text-align: center;
    font-size: 34rpx;
    color: #333333;
}
.pop_title{
    padding: 20rpx 0;
}

.bounced input{
    width: 450rpx;
    height: 50rpx;
    font-size: 28rpx;
    margin: 80rpx auto;
    border-bottom: 1rpx solid #eeeeee;
    text-align: left;
    padding: 10rpx 0;
}

.send_btn{
    width: 500rpx;
    height: 86rpx;
    border-top: 1rpx solid #eeeeee;
    display: flex;
    align-items: center;
}

.send_btn button{
    width: 50%;
    height: 86rpx;
    margin: 0;
    padding: 0;
    font-size: 30rpx;
}
.btn1{
    color: #333333;
    border-radius: 0 0 0 12rpx;
    border-right: 1rpx solid #eeeeee;
}
.btn2{
    color: #3c91e1;
    border-radius: 0 0 12rpx 0;
}

.headFix{
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  margin: 0 auto;
  width: 750rpx;
  display: flex;
  align-items: center;
  background: #252525;
  z-index: 99;
  padding: 20rpx 40rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  box-shadow: 0 2px 12px 0 rgba(255,255,255,.2);
  transition: all 0.5s;
  transform: translateY(-100%);
  opacity: 0;
}
.headFix.show{
  transform: translateY(0);
  opacity: 1;
}
.headFix .imgBox{
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 40rpx;
}
.headFix .imgBox image{
  border-radius: 50%;
}
.headFix .imgBox image{
  width: 100%;
  height: 100%;
}
.headFix .desc{
  display: flex;
  justify-content: center;
  /* align-items: center; */
  /* color: #fff; */
  flex: 1;
  flex-direction: column;
  color: #fff;
  font-size: 15px;
}
.headFix .desc view:last-of-type{
  color: #aeaeae;
  font-size: 13px;
  /* color: # */
}
.headFix .btn{
  width: 220rpx;
  height: 80rpx;
  background: #50a6f9;
  color: #fff;
  margin: 0;
  margin-left: 20rpx;
  border: none;
}

.perfect{
  z-index: 999;
  height: 120rpx;
  width: 100%;
  background: linear-gradient(to bottom, rgba(37,37,37,1),rgba(37,37,37,0.3));
  border-radius: 0;
}
.perfect image{
  width: 45rpx;
  height: 40rpx;
  margin-left: 40rpx;
}
.perfect .desc{
  flex:1;
  font-size: 26rpx;
  /* text-align: center; */
  font-weight: 500;
  color: #fff;
  line-height: 1.3rem;

}
.overflow2{
  text-overflow: -o-ellipsis-lastline;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
}
