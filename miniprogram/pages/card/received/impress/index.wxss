page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.ct_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
}
.ct{
  width: 690rpx;
  margin: 0 auto;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f5f5f5;
}
.ctBox{
  width: 690rpx;
  margin: 0 auto;
}
.ct_change{
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #000000;
  margin: 40rpx auto;
}
.change_left{
  width: 200rpx;
  font-size: 28rpx;
  color: #9D9D9D;
}
.change_left text{
  margin-left: 8rpx;
}
.iconshijian1{
  font-size: 28rpx;
}
.address{
  /*margin-left: 24rpx;*/
  margin-left: 6rpx;
}
.time{
  font-size: 32rpx;
  color: #929292;
}
.ct_left{
  display: flex;
  align-items: center;
}
.ct_right{
  font-size: 36rpx;
  color: #FFC163;
}
.img{
  width: 128rpx;
  height: 128rpx;
  border-radius: 90rpx;
}
.img image{
  width: 128rpx;
  height: 128rpx;
  border-radius: 90rpx;
}
.text{
  margin-left: 30rpx;
  font-size: 40rpx;
  color: #9D9D9D;
  line-height: 60rpx;
}
.name{
  font-size: 36rpx;
  color: #1E1E1E;
}
.name span{
  font-size: 28rpx;
  color: #B5B5B5;
  margin-left: 48rpx;
}
.ct_introduce .edit{
  font-size: 32rpx;
  color: #FFC163;
  width: 120rpx;
  justify-content: flex-end;
  display: flex;
}
.ct_introduce{
  width: 690rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 0;
}
.ct_textarea{
  width: 690rpx;
  margin: 0 auto;
}
.ct_textarea textarea{
  width: 690rpx;
  height: 300rpx;
  font-size: 28rpx;
  color: #2F2F2F;
}
.introduce{
  width: 100%;
  height: 100%;
  margin: 20rpx auto;
  background: #ffffff;
  font-size: 32rpx;
  color: #9D9D9D
}
.bounced{
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0 ;
  left: 0;
  bottom: 0;
  right: 0;
  background: rgba(0, 0,0,.5);
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pop_box{
  width: 500rpx;
  height: 400rpx;
  background: #ffffff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 34rpx;
  color: #333333;
}
.pop_title{
  padding: 20rpx 0;
}
input{
  width: 450rpx;
  height: 50rpx;
  font-size: 28rpx;
  margin: 80rpx auto;
  border-bottom: 1rpx solid #eeeeee;
  text-align: left;
  padding: 10rpx 0;
}
.btn{
  width: 500rpx;
  height: 86rpx;
  border-top: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
}
.btn button{
  width: 50%;
  height: 86rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
}
.btn1{
  color: #333333;
  border-radius: 0 0 0 12rpx;
  border-right: 1rpx solid #eeeeee;
}
.btn2{
  color: #3c91e1;
  border-radius: 0 0 12rpx 0;
}

.dibubutton{
  width: 100%;
  height: 94rpx;
  font-size: 32rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgb(80,166,249);
  position: fixed;
  bottom: 0;
  margin: 0;
  padding: 0;
  border-radius: 0;
}

.img{
  position: relative;
}
.to_perfect{
  position: absolute;
  background: #FE9c2A;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 10rpx;
  padding: 0 10rpx;
  z-index: 1;
  left: 45rpx;
  top: -5rpx;
  transform:rotate(25deg);
  line-height: 30rpx;
}