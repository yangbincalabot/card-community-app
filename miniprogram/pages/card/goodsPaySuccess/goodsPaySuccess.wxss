.main {
    width: 750rpx;
    height: 100%;
    padding-top: 120rpx;
}

.main .pay {
    width: 590rpx;
    height: 835rpx;
    margin: 0 auto;
    text-align: center;
}

.main .pay image {
    width: 140rpx;
    height: 140rpx;
}

.main .pay .p1 {
    font-size: 32rpx;
    color: rgb(51, 51, 51);
    margin: 30rpx 0;
}

.main .pay .p2 {
    font-size: 26rpx;
    color: rgb(136, 136, 136);
    margin-bottom: 20rpx;
}

.main .pay .p3 {
    font-size: 26rpx;
    color: rgb(136, 136, 136);
}

.main .pay .back {
    width: 590rpx;
    height: 94rpx;
    background: rgb(254, 191, 0);
    font-size: 34rpx;
    color: #fff;
    border-radius: 10rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 300rpx;
}

.main .pay .check {
    width: 590rpx;
    height: 94rpx;
    background: #fff;
    border: 1rpx solid rgb(254, 191, 0);
    font-size: 34rpx;
    color: rgb(254, 191, 0);
    border-radius: 10rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 40rpx;
}
