/**index.wxss**/

.main {
    width: 750rpx;
    height: 100%;
    position: relative;
}

.restaurant {
    width: 100%;
    position: absolute;
    bottom: 0;
    background: #fff;
    border-top-left-radius: 30rpx;
    border-top-right-radius: 30rpx;
}

.restaurant_box {
    width: 710rpx;
    /* border-bottom: 1rpx solid #f5f5f5; */
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30rpx 0;
}

.rest_img image {
    width: 120rpx;
    height: 120rpx;
    border-radius: 10rpx;
}

.rest_ct {
    width: 560rpx;
    line-height: 60rpx;
}

.firm {
    font-size: 30rpx;
    color: #333;
}

.add {
    font-size: 26rpx;
    color: #999;
}

.ct {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 26rpx;
    color: #333;
}

.icontel, .iconcanyin {
    color: #fbca19;
}
.icontel{
  margin-right: 10rpx;
}
.iconcanyin{
  margin-left: 10rpx;
}
.search {
    width: 710rpx;
    height: 80rpx;
    background: #fff;
    border-radius: 20rpx;
    position: fixed;
    top: 120rpx;
    left: 20rpx;
    z-index: 1;
    box-shadow: 0px 4rpx 16rpx 0px rgba(0, 0, 0, 0.14);
}

.search_view {
    width: 650rpx;
    height: 80rpx;
    background: #fff;
    margin: 0 auto;
    display: flex;
    align-items: center;
}

.search_view image {
    width: 66rpx;
    height: 66rpx;
}

.search_classify {
    height: 40rpx;
    border-left: 4rpx solid #999;
    display: flex;
    align-items: center;
    margin-left: 20rpx;
    padding: 0 20rpx;
    font-size: 34rpx;
    color: #333;
}

.iconyouxia {
    font-size: 16rpx;
    align-items: flex-end;
}

input {
    width: 400rpx;
    margin-left: 20rpx;
    font-size: 34rpx;
    color: #333;
}

.iconfenlei {
    font-size: 50rpx;
    color: #fbca19;
}

.more {
    width: 80rpx;
    height: 80rpx;
    background: #fff;
    border-radius: 90rpx;
    position: absolute;
    right: 5%;
    bottom: 30%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0px 4rpx 16rpx 0px rgba(0, 0, 0, 0.14);
}


.my_positon {
    width: 80rpx;
    height: 80rpx;
    background: #fff;
    border-radius: 90rpx;
    position: absolute;
    right: 5%;
    bottom: 40%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0px 4rpx 16rpx 0px rgba(0, 0, 0, 0.14);
}

.business {
    width: 80rpx;
    height: 80rpx;
    background: #fff;
    border-radius: 90rpx;
    position: absolute;
    right: 5%;
    bottom: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0px 4rpx 16rpx 0px rgba(0, 0, 0, 0.14);
}

.mask {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
}

.mask_box {
    width: 620rpx;
    padding: 50rpx 30rpx;
    z-index: 2;
    background: #fff;
    border-radius: 20rpx;
    line-height: 46rpx;
}

.icondelete {
    color: #fff;
    font-size: 64rpx;
    margin: 20rpx auto;
}

.registered {
    font-size: 38rpx;
    color: #000;
}

.reg_input {
    width: 560rpx;
    height: 100rpx;
    border-radius: 45rpx;
    border: 2rpx solid #ccc;
    margin: 10rpx auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 30rpx;
    color: #333;
    padding: 0 30rpx;
}

.reg_input text {
    width: 120rpx;
    text-align: right;
}

.reg_input span {
    color: #f00;
    margin-left: 20rpx;
}

.reg_input input {
    width: 380rpx;
    font-size: 30rpx;
    text-align: left;
}

.reg_title {
    text-align: left;
    font-size: 26rpx;
    color: #333;
}

.address {
    height: 40rpx;
    display: flex;
    align-items: center;
    padding: 0 10rpx;
    font-size: 30rpx;
    color: #333;
}

.reg_add .iconyouxia {
    color: #ccc;
}

.reg_add {
    display: flex;
}

.mask_box button {
    width: 620rpx;
    height: 100rpx;
    background: #fbca19;
    border-radius: 90rpx;
    font-size: 38rpx;
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 30rpx;
}

.downShow {
    width: 100rpx;
    height: 230rpx;
    background: #fff;
    position: absolute;
    z-index: 1;
    top: 120rpx;
    left: 145rpx;
    border-radius: 10rpx;
    padding: 30rpx;
    box-shadow: 0px 4rpx 16rpx 0px rgba(0, 0, 0, 0.14);
    text-align: center;
    line-height: 60rpx;
    font-size: 28rpx;
    color: #333;
}

.iconshengxu {
    position: absolute;
    top: -30rpx;
    color: #fff;
    font-size: 40rpx;
    left: 95rpx;
}

.cover-view {
    position: absolute;
    top: calc(50% - 425rpx);
    /* left: calc(50% - 300rpx); */
    left: calc(50% - 120rpx);
    /* opacity: .7; */
}

.flex-wrp {
    display: flex;
}

.flex-item {
    width: 250rpx;
    height: 45rpx;
    font-size: 26rpx;
    line-height: 45rpx;
    border-radius: 20rpx;
}

.show-radius {
    background: rgba(39, 130, 215, 0.9);
    text-align: center;
    color: #fff;
}

.img_icon{
  width: 55rpx;
  height: 55rpx;
}

.card_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
}
.card_view{
    width: 690rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1rpx solid #eeeeee;
    padding: 18rpx 0;
    margin: 0 auto;
    position: relative;
}

.card{
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #878787;
}
.card image{
    width: 110rpx;
    height: 110rpx;
    border-radius: 90rpx;
}
.card_title{
    font-size: 32rpx;
    color: #000000;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.card_title span{
    font-size: 24rpx;
    color: #878787;
    margin-left: 34rpx;
    max-width: 270rpx;
    display: inline-block;
    line-height: 1.2em;
    overflow: hidden;/*超出部分隐藏*/
    white-space: nowrap;/*不换行*/
    text-overflow:ellipsis;/*超出部分文字以...显示*/
}
.card_text{
    margin-left: 24rpx;
    font-size: 24rpx;
    color: #878787;
    line-height: 50rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.icontel{
    /* margin-right: 64rpx;
    font-size: 54rpx; */
    margin-right: 26rpx;
    font-size: 48rpx;
    display: inline-block;
}
.nexticon{
  margin-right: 36rpx;
   font-size: 48rpx;
   display: inline-block;
}
.site span{
  margin-left: 20rpx;
}