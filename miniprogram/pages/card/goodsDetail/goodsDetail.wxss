.coupon{
  width: 690rpx;
  height: 180rpx;
  margin: 0 auto;
  background: url(https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/coupon_bg3.png) no-repeat;
  background-size: 100%;
  margin-bottom: 36rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
}
.coupon .left :nth-child(1){
  font-size: 60rpx;
  color: rgb(255,111,97);
}
.coupon .left :nth-child(2){
  font-size: 26rpx;
  color: rgb(255,111,97);
}
.coupon .left :nth-child(3){
  font-size: 26rpx;
  color: rgb(170,170,170);
  margin-top: 15rpx;
}
.coupon .right{
  font-size: 28rpx;
  color: #fff;
}
.coupon image{
  width: 690rpx;
  height: 180rpx;
}