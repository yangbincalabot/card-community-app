.main{
  width: 750rpx;
  height: 100%;
  overflow: hidden;
  background: rgb(240,240,240);
}
swiper{ 
  background: #fff;
   height: 400rpx; 
   padding: 16rpx 0 10rpx 0; 
   text-align: center;
}
.slide-image{ 
  width: 750rpx; 
  /* background: #ce3;  */
  height: 400rpx; 
  margin: 0 auto; 
}
.main .text{
  width: 750rpx;
  background: #fff;
  position: relative;
  padding-bottom: 20rpx;
}
.main .text .title{
  font-size: 30rpx;
  color: #333333;
  width: 670rpx;
  margin: 0 auto;
}
.main .text .price{  
  display: flex;
  width: 700rpx;
  align-items: center;
  margin: 20rpx 0 20rpx 30rpx;
  
}
.main .text .price .p1{
  font-size: 46rpx;
  color: rgb(255,25,25);
}
.main .text .price .p2{
  font-size: 34rpx;  
  color: rgb(51,51,51);
  
}
.main .text .price .p2{
  position: relative;
  margin-left: 40rpx;
}
.main .text .price .p2 image{
  width: 77rpx;
  height: 30rpx;
  position: absolute;
  top: 8rpx;
  margin-left:10rpx;
}
.main .text .price button i{
  font-size: 24rpx;
  height: 100%;
}
.main .text .price button::after{
  border: none;
}
.main .text .price button .button_join{
  width: 74rpx;
  height: 54rpx;
  font-size: 25rpx;
  display: flex;
  align-items: center; 
  justify-content: space-between; 

}
.main .text .price button{
  position: absolute;
  top: 76rpx;
  right: 0;
  font-size: 24rpx;
  color: #ffffff;  
  width: 120rpx;
  height: 54rpx;
  border-radius: 27rpx 0 0 27rpx;
  background: linear-gradient(45deg,rgba(1,110,255,1) 0%,rgba(113,113,255,1) 100%);
}
.main .text .text2{
  width: 680rpx;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  margin-left: 40rpx;
  color: rgb(136,136,136);
}
.main .text .text2 .t1 i{
  margin-right: 20rpx;
}
.main .size1{
  width: 750rpx;
  height: 100rpx;
  background: #fff;
  margin: 20rpx 0 0 0;  
}
.main .size1 .size{
  width: 690rpx;
  height: 98rpx;
  display: flex;
  align-items: center;
  position: relative;
  margin: 0 auto;
  border-bottom: 1rpx solid rgb(221,221,221);
}
.main .size2 .size{
  width: 690rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  position: relative;
  margin: 0 auto;
}
.main .size1 .s1{
  font-size: 30rpx;
  color: rgb(136,136,136);
}
.main .size1 .s2{
  margin-left: 21rpx;
  font-size: 30rpx;
  color: rgb(51,51,51);
}
.main .size1 i{
  position: absolute;
  right: 0;
  color: rgb(204,204,204);
}
.main .size2{
  width: 750rpx;
  height: 100rpx;
  background: #fff;
  margin: 0 0 20rpx 0;  
  display: flex;
  align-items: center;
  position: relative;
}
.main .size2 .s1{
  font-size: 30rpx;
  color: rgb(136,136,136);
}
.main .size2 .s2{
  margin-left: 21rpx;
  font-size: 30rpx;
  color: rgb(51,51,51);
}
.main .size2 i{
  position: absolute;
  right: 0;
  color: rgb(204,204,204);
}
.main .prodetail{
  margin-top: 20rpx;
  width: 750rpx;
  height: 100%;
  background: #fff;  
  margin-bottom: 100rpx;
  padding-bottom: 20rpx;
}
.main .prodetail .tit{
  font-size: 34rpx;
  color: rgb(51,51,51);
  text-align: center;
  padding-top: 30rpx;
}
.main .prodetail .imgs{
  width: 750rpx;
}
.main .prodetail .img image{
  width: 750rpx;
}
.footer{
  width: 750rpx;
  height: 98rpx;
  position: fixed;
  bottom: 0;
  text-align: center;
  background: rgb(80,166,249);
  z-index: 1;
  color: #ffffff;
  line-height: 98rpx;
  font-size: 30rpx;
}

