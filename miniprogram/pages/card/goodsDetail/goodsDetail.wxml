<view class="main">
    <view>
        <swiper indicator-dots="{{indicatorDots}}" autoplay="{{autoplay}}" interval="{{interval}}" duration="{{duration}}">
            <block wx:for="{{ goods.image }}" wx:key="index">
                <swiper-item>
                    <image src="{{item}}" class="slide-image" mode="widthFix" />
                </swiper-item>
            </block>
        </swiper>
    </view>
    <view class='text'>
        <view class='title'>{{ goods.title }}</view>
        <view class='price'>
            <view class='p1'>￥{{ goods.price }}</view>
            <!-- <view class='p2'>￥258.00<image src='../../../images/icon-pro.png'></image></view>       -->
            <button class='p3'>
                <view class='button_join'>
                    <i class='icon iconfont iconfenxiang'></i>
                    <text>分享</text>
                </view>
            </button>
        </view>
        <view class='text2'>
            <view class='t1'>
                <i>浏览量</i>{{ goods.views }}</view>
            <view class='t1'>
                <i>销量</i>{{ goods.sales }}</view>
        </view>
    </view>
    <view class='prodetail'>
        <view class='tit'>商品详情</view>
        <view class='img'>
            <view class='imgs'>
                {{ goods.content }}
                <block wx:for="{{  goods.images }}" wx:key="index" style="margin-bottom:120rpx">
                    <image src='{{ item }}'  mode="widthFix"></image>
                </block>
            </view>
        </view>
    </view>
    <view class='footer' bindtap="onBuy">
      立即购买
    </view>
</view>