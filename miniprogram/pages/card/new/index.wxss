/* pages/card/new/index.wxss */
@import 'ripples.min.wxss';
.container{
  width: 100vw;
  display: flex;
  justify-content: center;
}
.con-wrap{
  min-height: 100vh;  
}
page{
  background: #f5f5f5;
}
.main{
  width: 100%;
  height: 100%;
}
.userCard{
  width: 100%;
}
.card_bg{
  width: 690rpx;
  height: 426rpx;
  margin: 20rpx auto;
  background: url("https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/card_icon1.png") no-repeat;
  background-size: 100%;
  color: #ffffff;
  display: flex;
  align-items: center;
}
.card_ct{
  width: 560rpx;
  margin: 0 auto;
  opacity: .7;
}
.ct1{
  font-size: 36rpx;
  line-height: 100rpx;
}
.ct2{
  font-size: 44rpx;
  line-height:70rpx;
}
.ct2 span{
  font-size: 34rpx;
  margin-left: 40rpx;
}
.ct3{
  font-size: 30rpx;
  line-height: 50rpx;
  display: flex;
  align-items: center;
  margin: 10rpx 0;
}
.ct3 image{
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}
.user_code{
  width: 690rpx;
  height: 640rpx;
  background: #ffffff;
  border-radius: 10rpx;
  box-shadow: 10rpx 10rpx 10rpx #e5e5e5;
  margin: 20rpx auto;
  text-align: center;
  font-size: 30rpx;
  color: #666666;
}
.user_code image{
  width: 400rpx;
  height: 400rpx;
  margin: 20rpx auto;
}
button{
  width: 560rpx;
  height: 88rpx;
  background: rgb(80,166,249);
  padding: 0;
  color: #ffffff;
  font-size: 40rpx;
  margin: 30rpx auto;
  display: flex;
  align-items: center;
  justify-content: center;

}
.footer{
  width: 100%;
  height: 80rpx;
  background: #ffffff;  
  font-size: 30rpx;
  color: #333333;
}
.footer_box .imgs image{
  width: 52rpx;
  height: 52rpx;
  border-radius: 90rpx;
  margin-right: -10rpx;
}
.footer_box .imgs{
  max-width: 405rpx;
  height: 52rpx;
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
  padding-right: 25rpx;
  border-radius: 25rpx;
  margin: 0 25rpx;
}
.footer_box{
  width: 710rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  margin: 0 auto;
}
/* 滑动后页面css */
.card{
  width: 690rpx;
  height: 100%;
  margin: 0 auto;
  border-radius: 120rpx 0 40rpx 0;
  padding: 28rpx 0;
}
.card_box{
  width: 690rpx;
  height: 290rpx;
  background: url(https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/card_icon2.png) no-repeat;
  background-size: 100%;
  margin: 0 auto;
}
.card_text{
  width: 570rpx;
  height: 330rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  margin: 0 auto; 
}
.card_text image{
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 50rpx;
}
.btn{
  margin-bottom: 36rpx;
  width:206rpx;
  height:64rpx;
  border-radius:10rpx;
  border:2rpx solid rgba(255,193,99,1);
  font-size: 32rpx;
  color: #FFC163;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card_view{
  width: 690rpx;
  background: #ffffff;
  border-radius: 0 0 20rpx 20rpx;
  padding-bottom: 32rpx;
}
.access{
  width: 570rpx;
  margin: 0 auto;
  text-align: right;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #A1A1A1;
    position: relative;
}
.icondianzanliang{
  margin-right: 5rpx;
}
.num{
  font-size: 24rpx;
  color: #FFC163;
}
.msg{
  width: 630rpx;
  margin: 0 auto;
}
.msg_box{
  width: 630rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eeeeee;
  padding-bottom: 20rpx;
}
.msg_left image{
  width: 116rpx;
  height: 116rpx;
  border-radius: 90rpx;
}
.line{
  width: 4rpx;
  height: 58rpx;
  background: #979797;
  margin:0 30rpx 0 20rpx;
}
.msg_right{
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #929292;
  margin-left: 50rpx;
}
.name{
  font-size: 36rpx;
  color: #000000;
  line-height: 60rpx;
}
.name span{
  height:34rpx;
  background:linear-gradient(180deg,rgba(143,143,143,1) 0%,rgba(0,0,0,1) 100%);
  border-radius:17rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  padding: 5rpx 20rpx; 
  margin-left: 58rpx;
}
.msg_view{  
  display: flex;
  align-items: center;
  margin-left: 30rpx;
  padding: 30rpx 0 0 0;
}
.iconshouji{
  font-size: 44rpx;
  color: #FFC163;
}
.msg_text{
  width: 420rpx;
  margin-left: 34rpx;
  font-size: 24rpx;
  color: #898989;
  line-height: 40rpx;
  padding: 14rpx 0;
}
.email{
  font-size: 32rpx;
}
.msg_ct{
  font-size: 32rpx;
  color: #000000;
}
button{
  width:454rpx;
  height:90rpx;
  background:rgb(80,166,249);
  border-radius:14rpx;
  font-size: 32rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
}
.title_left{
  width:16rpx;
  height:34rpx;
  background:rgba(255,193,99,1);
  border-radius:8rpx;
  margin-right: 14rpx;
}
.title{
  width: 690rpx;
  font-size: 36rpx;
  color: #333333;
  display: flex;
  align-items: center;
  margin: 20rpx auto;
}
.firmCard{
  width:690rpx;
  height:350rpx;
  background:url(https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/card_bg.png) no-repeat;
  background-size: 100%;
  border-radius:12rpx;
  margin: 20rpx auto;
  text-align: center;
  font-size: 40rpx;
  color: #FFFFFF;
  line-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.introduce{
  width:642rpx;
  min-height:266rpx;
  background:rgba(43,43,43,1);
  border-radius:12rpx;
  border:2rpx dotted #ffffff ;
  margin: 20rpx auto;
  font-size: 28rpx;
  color: #FFFFFF;
  padding: 42rpx 24rpx;
}
.imgs{
  width: 690rpx;
  margin: 20rpx auto;
  border:2rpx dotted #ffffff ;
}
.imgs image{
  width: 690rpx;
  border-radius: 14rpx;
}
.iconfanhuix{  
  color: #ffffff;
}
.back{
  padding-top: 70rpx;
  padding-left: 30rpx;
}
.msg_view image{
  width:70rpx;
  height: 70rpx;
}
.btnAll{
  width: 690rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
}
.btnAll button{
  width: 260rpx;
  height: 80rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  font-size: 32rpx;
}
.btnAll .btn1{
  border: 1rpx solid rgba(255,193,99,1);
  color: #FFC163;
  background: #ffffff;
}
.btnAll .btn2{
  background: rgb(80,166,249);
}
.collect_btn{
    border: 1rpx solid rgba(255,193,99,1);
    color: #FFC163;
    background: #ffffff;
    width: 160rpx;
    text-align: center;
    position: absolute;
    font-size: 32rpx;
    height: 56rpx;
    line-height: 56rpx;
}