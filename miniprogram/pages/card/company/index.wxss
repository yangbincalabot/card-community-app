/* pages/card/company/index.wxss */
page{
    background: #f5f5f5;
    width: 100%;
    height: 100%;
}
.firm{
    width: 100%;
    height:368rpx;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 32rpx;
    color: #000000;
    line-height: 70rpx;
}
.firm image{
    width: 130rpx;
    height: 130rpx;
    border-radius: 14rpx;
    margin: 0 auto;
}
.btn{
    font-size: 32rpx;
    color: #FFA41A;
}
.initial{
    font-size: 20rpx;
    color: #4F4F4F;
    width: 690rpx;
    margin: 4rpx auto;
}
.ct_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
}
.ct{
    width: 690rpx;
    border-bottom: 1rpx solid #eeeeee;
    padding: 18rpx 0;
    margin: 0 auto;
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #888888;
}
.ct image{
    width: 110rpx;
    height: 110rpx;
    border-radius: 90rpx;
}
.title{
    font-size: 32rpx;
    color: #000000;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
}
.title span{
    font-size: 24rpx;
    color: #878787;
    margin-left: 34rpx;
}
.text{
    width: 560rpx;
    margin-left: 34rpx;
    font-size: 28rpx;
    color: #878787;
    line-height: 50rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}