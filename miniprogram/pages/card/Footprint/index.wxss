/* pages/card/Footprint/index.wxss */
page{
  background-color: #f5f5f5;
}
.ct_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
}
.ct_view{
  width: 690rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eeeeee;
  padding: 10rpx 0;
  margin: 0 auto;
}
.ct{  
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #878787;
}
.ct image{
  width: 110rpx;
  height: 110rpx;
  border-radius: 15rpx;
  /* border-radius: 90rpx; */
}
.imgs{
	width: 110rpx;
	height: 110rpx;
  position: relative;
}
.vip{
	position: absolute;
	width: 30rpx;
	height: 30rpx;
	bottom: 0;
	right: 5rpx;
}
.title{
  font-size: 32rpx;
  color: #000000;
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
  width: 300rpx;
}
.title span{
  font-size: 24rpx;
  color: #878787;
  margin-left: 34rpx;
}
.text{
  margin-left: 24rpx;
  font-size: 24rpx;
  color: #878787;
  /* line-height: 50rpx; */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.text view{
  margin-bottom: 5rpx;
}
.iconsousuox{
  font-size: 64rpx;
  color: rgba(0, 0, 0, .8)
}
.label{
  display: inline-block;
  height:40rpx;
  line-height: 40rpx;
  /* background:linear-gradient(180deg,rgba(255,202,122,1) 0%,rgba(255,156,6,1) 100%); */
  background-color: #F3F3F3;
  font-size: 24rpx;
  color: #B0B0B0;
  padding: 0rpx 10rpx;
}
