/* pages/card/memberRZ/index.wxss */
page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
  padding-top: 30rpx;
}
.main .title{
  margin-left: 30rpx;
  font-size: 28rpx;
  color: rgb(153,153,153);
}
.main .card{
  width: 690rpx;
  height: 100%;
  margin: 0 auto;
}
.main .card .card_content{
  width: 690rpx;
  height: 90rpx;
  background: rgb(255,254,255);
  border-radius: 20rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  padding-left: 20rpx;
}
.main .card .card_content .logo{
  width: 70rpx;
  height: 70rpx;
  margin: 40rpx 30rpx;
}
.main .card .card_content .logo image{
  width: 70rpx;
  height: 70rpx;
}
.main .card .card_content .content{
  line-height: 60rpx;
  width: 100%;
}
.main .card .card_content .content .bank_title{
  display: inline-block;
  width: 48%;
  font-size: 28rpx;
  color: rgb(51,51,51);
}
.main .card .card_content .content .bank_title_right{
  font-size: 28rpx;
  color: rgb(51,51,51);
  display: inline-block;
  width: 48%;
  text-align: right;
}
.main .card .card_content .content .name_account{
  font-size: 28rpx;
  color: rgb(102,102,102);
}
.main .card .card_content .content .name_account i{
  margin-left: 145rpx;
}
.main .btn{
  width: 590rpx;
  height: 94rpx;
  background: rgb(254,191,0);
  border-radius: 10rpx;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  margin-top: 90rpx;
  margin-bottom: 38rpx;
}

.main .add_btn{
  width: 590rpx;
  height: 94rpx;
  background: rgb(254,191,0);
  border-radius: 10rpx;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  margin-bottom: 50rpx;
}

/* .selected{ */
/* border: 1rpx solid rgb(254,191,0); */
/* } */

.userCard{
position: relative;
width: 100%;
}
.card_bg{
width: 690rpx;
height: 360rpx;
margin: 20rpx auto 0 auto;
background: url("https://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/card_icon1.png") no-repeat;
background-size: 100%;
color: #ffffff;
display: flex;
align-items: center;
border-radius: 18rpx;
}
.card_ct{
width: 560rpx;
margin: 0 auto;
}
.ct1{
font-size: 34rpx;
line-height: 70rpx;
}
.ct2{
font-size: 42rpx;
line-height:70rpx;
margin-bottom: 10rpx;
}
.ct2 span{
font-size: 32rpx;
margin-left: 40rpx;
}
.ct3{
font-size: 28rpx;
line-height: 40rpx;
display: flex;
align-items: center;
margin: 10rpx 0;
width: 100%;
}
.ct3 text{
opacity: 0.7;
}
.ct3 image{
width: 35rpx;
height: 35rpx;
margin-right: 20rpx;
}
.right_item {
line-height: 120rpx;
text-align: center;
color: #fff;
font-weight: 500;
display: flex;
align-items: center;
justify-content: center;
border-radius: 20rpx;
flex-direction: column;
}


.OCRscan{
background: #50a6f9;
color: #ffffff;
border: 1px solid #8dbffc;
flex-direction: row;
width: 690rpx;
height: 280rpx;
margin: 40rpx auto 80rpx auto;
}
.OCRscan image{
margin-right: 20rpx;
width: 50rpx;
height: 50rpx;
display: inline-block;
overflow: hidden;
}

.qiehuan{
position: absolute;
right: 38rpx;
top: 6rpx;
font-size: 28rpx;
}

.userCard .selected{
color: rgb(254,191,0);
}
.sub-btn{
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background-color: #50A6F9;
  font-size: 40rpx;
  text-align: center;
  position: fixed;
  bottom: 0;
  color: #fff;
}