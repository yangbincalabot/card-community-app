/* pages/card/societyIndex/societyIndex.wxss */
page{
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}
.search{
  width: 100%;
  height: 440rpx;
  background: #ffffff;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: url(http://szdbi.oss-cn-shenzhen.aliyuncs.com/mingpian/ing-benjing.png) no-repeat;
  background-size: 100% 100%;
  position: relative;
}
.navbar {
  width: 100%;
  overflow: hidden;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
  flex-shrink: 0;
  /* flex-direction: column */
}
.navbar-title {
  width: 100%;
  box-sizing: border-box;
  padding-left: 115px;
  padding-right: 115px;
  height: 32px;
  line-height: 32px;
  text-align: center;
  position: absolute;
  left: 0;
  z-index: 10;
  color: #333;
  font-size: 16px;
  font-weight: 500;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
}
.navbar-action-wrap {
  display: -webkit-flex;
  display: flex;
  -webkit-box-align: center;
  -ms-flex-align: center;
  -webkit-align-items: center;
  align-items: center;
  position: absolute;
  left: 10px;
  z-index: 11;
  line-height: 1;
  padding-top: 2px;
  padding-bottom: 2px;
  background: rgba(255,255,255,0.5)
}

.navbar-action-group {
  /* border: 1px solid #f0f0f0; */
  border-radius: 20px;
  overflow: hidden;
}

.navbar-action_item {
  padding: 3px 0;
  color: #333;
}

.navbar-action-group .navbar-action_item {
  /* border-right: 1px solid #f0f0f0; */
  padding: 3px 14px;
}

.navbar-action-group .last {
  border-right: none;
}
.navbar image{
  height: 35rpx;
  width: 35rpx;
}
.navbar-action-wrap-span{
  color: #fff;
}
.navbar-action-wrap-span{
  display: inline-block;
  line-height: 25rpx;
  height: 25rpx;
  border-right: 1rpx solid #B5B5B5;
  padding: 0 2rpx;
}
.society-nav-tit{
  display: flex;
  align-items: center;
  font-size: 48rpx;
  font-weight: 800;
}
.society-nav-tit image{
  width: 70rpx;
  height: 70rpx;
  margin-right: 5rpx;
}
.society-nav-pow{
  position: relative;
}
.society-nav-box{
  position: absolute;
  top: -40rpx;
  left: 25rpx;
  background-color: #fff;
  padding: 30rpx;
  width: 650rpx;
  border-radius: 20rpx;
}
.society-nav-one{
  padding: 30rpx 0;
}
.society-nav-one,.society-nav-two{
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.society-nav-list .society-nav-tab image{
  width: 90rpx;
  height: 90rpx;
  display: block;
  margin: 0 auto;
}
.society-nav-list .society-nav-tab{
  text-align: center;
}

.society-nav-list .society-nav-tab text{
  display: block;
  font-size: 28rpx;
  margin-top: 10rpx;
}
.ct_box{
  width: 100%;
  height: 100%;
  background: #ffffff;
  margin-bottom: 150rpx;
  
}
.ct{
  width: 710rpx;
  border-bottom: 1rpx solid #eeeeee;
  margin: 0 auto;
  padding: 22rpx 0 0 0;
}
.ct_msg{
  width: 710rpx;
  display: flex;
  align-items: center;
}
.msg_left{
  width:224rpx;

  height:150rpx;
  position: relative;
}
.msg_left image{
  width:224rpx;
  height:150rpx;
  border-radius: 10rpx;
}
.msg_left text{
  position: absolute;
  font-size:24rpx;
  color: #FFFFFF;
  height:38rpx;
  background:rgba(255,193,99,1);
  z-index: 1;
  left: 0;
  padding: 0 14rpx;
  border-radius: 7rpx 0;
}
.msg_right{
  margin-left: 14rpx;
  line-height: 40rpx;
}
.msg_title{
  font-size: 30rpx;
  color: #303133;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.msg_text text{
font-size: 26rpx;
}
.msg_text{
  font-size: 24rpx;
  color: #909399;
  margin-top: 20rpx;
  width: 472rpx;
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
}
.iconshijian,.iconlocation{
  font-size: 26rpx;
  margin-right: 5rpx;
}
.all{
  width: 710rpx;
  margin: 20rpx auto;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #909399;
}
.all image{
  width: 52rpx;
  height: 52rpx;
  border-radius: 90rpx;
  margin-right: -10rpx;
}
.imgs{
  max-width: 445rpx;
  height: 52rpx;
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
  padding-right: 25rpx;
  border-radius: 25rpx;
}
.all text{
  width: 200rpx;
  margin-left: 20rpx;
}

.meeting text{
  background:linear-gradient(180deg,rgba(68,153,241,1) 0%,rgba(4,121,242,1) 100%);
  /* border-radius: 0 4rpx 4rpx 0; */
}
.society-apply-cutover{
  display: flex;
  align-items: center;
  height: 90rpx;
  margin-top: 405rpx;
  color: #666666;
  font-size: 36rpx;
  padding: 0 30rpx;
  font-weight: 800;
}
.society-apply-cutover view:nth-of-type(1){
  margin-right: 20rpx;
}
.action{
  color: #000000;
  font-size: 48rpx;
}
