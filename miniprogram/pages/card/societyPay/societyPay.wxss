/* pages/pay/index/index.wxss */
page{
    background: #f5f5f5;
}
.main{
    width: 750rpx;
    height: 100%;
    background: #f5f5f5;
    padding-top: 20rpx;
}
.main .money{
    width: 750rpx;
    height: 100rpx;
    margin-bottom: 20rpx;
    background: #fff;
}
.main .money .ct{
    height: 100rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 20rpx;
}
.main .money .ct .c1{
    font-size: 32rpx;
    color: rgb(51,51,51);
}
.main .money .ct .c2{
    font-size: 32rpx;
    color: rgb(51,51,51);
}
.main .money .ct .c2 i{
    color: rgb(255,25,25);
    margin-right: 5rpx;
}
.main .content{
    width: 750rpx;
    height: 100%;
    background: #fff;
}
.main .content .c1{
    width: 690rpx;
    height: 106rpx;
    border-bottom: 1rpx solid rgb(229,229,229);
    margin: 0 auto;
    font-size: 30rpx;
    color: rgb(51,51,51);
    display: flex;
    align-items: center;
}
.main .content .wx{
    width: 690rpx;
    height: 106rpx;
    display: flex;
    align-items: center;
    margin: 0 auto;
    font-size: 30rpx;
    color: rgb(51,51,51);
    /* position: relative; */
    justify-content: space-between;
}
.main .content .wx i{
    color: rgb(5,175,16);
    margin-right: 20rpx;
}
.main .content .offline{
    width: 690rpx;
    height: 106rpx;
    display: flex;
    align-items: center;
    margin: 0 auto;
    font-size: 30rpx;
    color: rgb(51,51,51);
    /* position: relative; */
    justify-content: space-between;
}
.main .content .offline i{
    color: rgb(253,205,15);
    margin-right: 20rpx;
}
.main .payment{
    width:612rpx;
    height:90rpx;
    background:linear-gradient(180deg,rgba(132,132,132,1) 0%,rgba(0,0,0,1) 100%);
    border-radius:14rpx;
    font-size: 32rpx;
    color: rgb(255,255,255);
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 90rpx auto;
}
/* 提现密码css */
.pwd_box{
    width: 100%;
    height: 100%;
    position:fixed;
    background:rgb(0,0,0,0.5);
    top: 0;
    z-index: 999;
    overflow: hidden;
}
.pwd_six_title{
    width: 690rpx;
    display: flex;
    margin: 20rpx auto;
    align-items: center;
    justify-content: center;
    font-size: 34rpx;
    color: #1e1e1e;
    position: relative;
}
.pwd_six_title .icon{
    position: absolute;
    left: 0;
}
.pwd_six_box{
    display: flex;
    width: 710rpx;
    justify-content: center;
    margin:5% auto;
    text-align: center;
}
.box{
    /* flex: 1; */
}
.box_border{
    width: 110rpx;
    height: 80rpx;
    border: 1px solid #bfbfbf;
    border-right:0;
    margin: auto;
    /* line-height:1; */
}
.pwd_hide{
    height: 80rpx;
    font-size:50rpx;
    display: flex;
    line-height: 40rpx;
    align-items: center;
    justify-content: center;
}
.number{
    display: flex;
    flex-wrap: wrap;
    text-align: center;
}
.password{
    width: 25%;
    flex-grow:1;
    padding: 3%;
    font-size:40rpx;
    border: 1px solid #eee;
    border-bottom: 0;
    border-right: 0;

}

.password:active{
    background: #eee;
}
/* 密码框 */
.masks{
    bottom:0%;
    position: fixed;
    background: #fff;
    width: 100%;
    transition:.5s;
}
.bot{bottom: 0;}
.redspan{
    font-size: 26rpx;
    color: rgb(255,25,25);
}