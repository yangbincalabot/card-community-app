/* pages/card/group/index/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.ct_box{
    width: 100%;
    background: #ffffff;
    margin-bottom: 120rpx;
}
.ct{
    width: 690rpx;
    margin: 0 auto;
    border-bottom: 1rpx solid #eeeeee;
    padding: 28rpx 0;
    font-size: 32rpx;
    color: #1E1E1E;
    display: flex;
    align-items: center;
}
button{
    width: 100%;
    height: 94rpx;
    font-size: 32rpx;
    color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(80,166,249);
    position: fixed;
    bottom: 0;
    margin: 0;
    padding: 0;
    border-radius: 0;
}