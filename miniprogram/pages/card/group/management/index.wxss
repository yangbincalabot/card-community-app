/* pages/card/group/management/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.title{
    font-size: 28rpx;
    color: #464646;
    margin: 8rpx auto;
    margin-left: 30rpx;
}
.input_box{
    width: 100%;
    height: 98rpx;
    background: #ffffff;
}
input{
    width: 690rpx;
    height: 98rpx;
    margin: 0 auto;
    font-size: 28rpx;
}
.staff{
    width: 100%;
    height: 100%;
    background: #ffffff;
    padding: 42rpx 0 28rpx 0;
}
.staff_view{
    width: 690rpx;
    margin: 0 auto;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
}
.staff_box{
    margin-right: 40rpx;
    margin-bottom: 20rpx;
    position: relative;
}
.iconshanchu1{
    position: absolute;
    top: 0;
    color: rgba(0, 0, 0, .8);
}
.staff_box image{
    width: 98rpx;
    height: 98rpx;
    border-radius: 90rpx;
}
.name{
    font-size: 28rpx;
    color: #464646;
    width: 84rpx;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
}
.operation{
    margin-right: 40rpx;
    margin-bottom: 20rpx;
}
.operation image{
    width: 80rpx;
    height: 80rpx;
}
button{
    width:612rpx;
    height:90rpx;
    line-height: 90rpx;
    border-radius:14rpx;
    margin: 60rpx auto;
    font-size: 32rpx;
    color: #FFFFFF;
}
.btn1{
    background:rgba(255,154,1,1);
}
.btn2{
    background:#353535;
}