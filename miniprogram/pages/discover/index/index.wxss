/* pages/discover/index/index.wxss */
page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  background: #f5f5f5;
}
.main .page_row{
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
}
.main .page_row .search{  
  width: 600rpx; 
  height: 70rpx; 
}  
.main .page_row .search .search_arr placeholderStyle{
  font-size: 28rpx;
  color: rgb(178,178,178);
}
.main .page_row .search .search_arr {  
  border: 1px solid rgb(230,230,234);  
  border-radius: 90rpx;  
  margin-left: 30rpx;  
}  

.main .page_row .search .search_arr input{
	text-align: center;
  margin-left: 20rpx; 
  height: 70rpx;  
  font-size: 28rpx;
  color: rgb(178,178,178);
}  
  
.sousuo {  
  font-size: 28rpx;
  color: rgb(254,191,0); 
  margin-right: 48rpx; 
}
.main .scroll_box{
  overflow: hidden;
  width: 100%;
  height: 86rpx;
  background: #fff;
  padding-top: 28rpx;
  white-space: nowrap;
}
.main .scroll_box .tab {
  display: flex;
	align-items: center;
	font-size: 30rpx;
	color: #353535;
}
.main .scroll_box .tab i{
  margin-left: 15rpx;
	font-size: 24rpx;
	color: #cccccc;
}

.main .scroll_box .t{
  width: 33.3%;
  font-size: 30rpx;
  color: rgb(53,53,53);
  text-align: center;
  white-space: nowrap;
}
.main .scroll_box .tab .active{
  color: rgb(254,191,0);
}
.main .content{
  margin-top: 20rpx;
  margin-bottom: 0;
}
.main .content .c{
  width: 750rpx;
  /* height: 260rpx; */
  margin-bottom: 20rpx;
  background: #fff;
}
.main .content .c .c1{
  display: flex;
}
.main .content .c .c1 .img{  
  width: 180rpx;
  height: 160rpx;
  margin: 30rpx 20rpx 15rpx 30rpx;
}
.main .content .c .c1 image{
  width: 180rpx;
  height: 160rpx;
  border-radius: 5rpx;
	margin-top: 10rpx;
}
.main .content .c .c1 .text{
  margin: 30rpx 28rpx 0 0;
}
.main .content .c .c1 .text .t1{
  font-size: 30rpx;
  color: rgb(51,51,51);
  overflow : hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.main .content .c .c1 .text .t2{
  font-size: 26rpx;
  color: rgb(102,102,102);
  margin: 20rpx 0;
}
.main .content .c .c1 .text .t2 i{
  margin-left: 20rpx;
}
.main .content .c .c1 .text .t3{
  width: 120rpx;
  height: 36rpx;
  color: rgb(253,114,95);
  border: 1rpx solid rgb(253,114,95);
  border-radius: 5rpx;
  font-size: 26rpx;
  text-align: center;
}
.main .content .footer{
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx 30rpx 30rpx;
}
.main .content .footer .f1{
  font-size: 28rpx;
  color: rgb(96,149,246);
}
.main .content .footer .f2{
  font-size: 28rpx;
  color: rgb(255,25,25);
}