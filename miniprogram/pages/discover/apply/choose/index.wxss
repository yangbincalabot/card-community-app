/* pages/discover/apply/choose/index.wxss */
page{
  background: #f5f5f5;
}
.main{
  width: 750rpx;
  height: 100%;
  padding-top: 20rpx;
}
.main .title{
  width: 750rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  background: #fff;
  font-size: 30rpx;
  margin: 33rpx 0;
}
.main .title i{
  color: rgb(254,191,0);
  margin: 0 20rpx 0 30rpx;
}
.product-list {
  background: #f5f5f5;
  /* min-height: 1000rpx; */
}
.product-container{
  padding-bottom: 160rpx;
}
.product-list .product-item {
  position: relative;
  width: 100vw;
  /* border-bottom: 2rpx solid #E9E9E9; */
  box-sizing: border-box;
  background: #fff;
  z-index: 999;
  /* margin-top: 20rpx; */  
  border-bottom: 1rpx solid rgb(204,204,204); 
  
}

.slide-product-list .slide-product-item {
  position: relative;
  width: 100vw;
  /* border-bottom: 2rpx solid #E9E9E9; */
  box-sizing: border-box;
  background: #fff;
  z-index: 999;
}

.product-list .product-item movable-area {
  height: 140rpx;
  width: calc(100vw - 120rpx);
}

.product-list .product-item movable-view {
  height: 140rpx;
  width: 100vw;
  background: #fff;
  z-index: 999;
}

.product-list .product-item .delete-btn {
  width: 150rpx;
  height: 140rpx;
  background: #f96363;
  color:#fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  right: 0;
  top: 0;
}

.product-list .product-item-wrap {
  width: 100%;
  height: 140rpx;
  background: #fff;
  line-height: 40rpx;
  /* margin-top: 30rpx; */
  position: relative; 
}
 .content{
  width: 750rpx;
  height: 100%;
  background: #fff;
}
 .content .c{
  margin: 0 auto;
  height: 140rpx;
  display: flex;
  align-items: center;
  /* justify-content: space-around; */
  position: relative;
  border-bottom: 1rpx solid rgb(204,204,204); 
}
 .content .c .content_msg{
 margin-left: 30rpx;
 line-height: 50rpx;
}
 .content .c .content_msg .m1{
  font-size: 30rpx;
  color: rgb(51,51,51);
}
 .content .c .content_msg .m1 i{
  margin: 0 20rpx;
}
 .content .c .content_msg .m2{
  font-size: 30rpx;
  color: rgb(153,153,153);
}
 .content .c .content_add{
  position: absolute;
  right: 30rpx;
}
.main .payment{
  width: 750rpx;
  height: 98rpx;
  position: fixed;
  bottom: 0;
  background: rgb(254,191,0);
  font-size: 32rpx;
  color: rgb(255,255,255);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}
.icon{
  margin-left: 20rpx;
}