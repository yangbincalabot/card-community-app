}
.main .content .c .c1 .text .t1{
  font-size: 32rpx;
  color: rgb(51,51,51);
  overflow : hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.main .content .c .c1 .text .t2{
  font-size: 28rpx;
  color: rgb(51,51,51);
  margin: 20rpx 0;
}
.main .content .c .c1 .text .t2 i{
  margin-left: 20rpx;
}
.main .content .c .c1 .text .t3{
