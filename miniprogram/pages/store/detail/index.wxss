/* pages/product/detail/index.wxss */
.main{
  width: 750rpx;  
}
swiper{ 
  background: #fff;
   height: 400rpx; 
   padding: 16rpx 0 10rpx 0; 
   text-align: center;
}
.icondizhi2{
	margin-right: 10rpx;
	font-size: 38rpx;
}
.icondianhua{
	margin-right: 10rpx;
	font-size: 38rpx;
}
.content_address{
	display: flex;
	align-items: center;
}
.content_address :nth-child(2){	
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.slide-image{ 
  width: 750rpx;
  height: 400rpx; 
  margin: 0 auto; 
}
.main .content{
  width: 680rpx;
  margin: 30rpx auto;
  line-height: 50rpx;
}
.content_name{
	width: 690rpx;
	margin: 0 auto;
	display: flex;
	align-items: center;
}
.content_name span{
	overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.content_name i{
	min-width: 100rpx;
	height: 34rpx;
	display: flex;
	justify-content: center;
	align-items: center;
	font-size: 24rpx;
  border: 1rpx solid rgb(254,167,0);
  color: rgb(254,167,0);
  border-radius: 5rpx;
  margin-left: 20rpx;
}
.main .content :nth-child(1){
  font-size: 30rpx;
  color: rgb(51,51,51);
}
.main .content :nth-child(1) i{
  color: rgb(254,167,0);  
}
.main .content :nth-child(2){
  font-size: 28rpx;
  color: rgb(102,102,102);
	overflow: hidden;
}
.main .content :nth-child(3){
  font-size: 28rpx;
  color: rgb(102,102,102);
}
.main .foot{
  width: 750rpx;
  height: 98rpx;
  display: flex;
  position: fixed;
  bottom: 0;
}
.main .foot .left{
  display: flex;
  align-items: center;
  justify-content: center;
}
.main .foot .left .l{
  font-size: 24rpx;
  color: rgb(102,102,102);
  margin: 0 auto;
}
.main .foot .left{
  width: 250rpx;
  height: 98rpx;
  background: rgb(245,245,245);  
  display: flex;
  align-items: center;
}
.main .foot .right{
  width:502rpx;
  height: 98rpx;
  background: rgb(255,227,0);
  font-size: 32rpx;
  color: rgb(51,51,51); 
  display: flex;
  justify-content: space-around;
  align-items: center;
}
