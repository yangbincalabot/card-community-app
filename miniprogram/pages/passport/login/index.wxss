
.header {
    margin: 90rpx auto;
    border-bottom: 1px solid #ccc;
    text-align: center;
    width: 650rpx;
    height: 300rpx;
}

.header .wechat-logo {
    width: 200rpx;
    height: 200rpx;
    margin: auto;
}

.font-size-190{
    font-size: 190rpx;
    color: #1AAD19;
}

.content {
    margin: 0 50rpx 90rpx 50rpx;
}

.content text {
    display: block;
    color: #9d9d9d;
    margin-top: 40rpx;
}

.bottom {
    display: inline-block;
    width: 38%;
    border-radius: 80rpx;
    /* margin: 70rpx 50rpx; */
    margin-left: 4%;
    font-size: 35rpx;
}

.notlog {
  margin-left: 10%;
  background: white;
  border: 1rpx solid pink;
  color: pink;
}