/* pages/reviewList/index/index.wxss */

.main .review{
  /* height: 606rpx; */
  padding-top: 20rpx;
  background: #fff;
}

.main .review .footer .foot{
  width: 690rpx;
  height: 300rpx;
  border-radius: 20rpx;
  border: 2rpx solid #ccc;
  margin: 30rpx auto;
  position: relative;
  display: block;
  margin-left: 30rpx;
}
.main .review .footer{
  width: 100%;
}
.foot image{
  width: 690rpx;
  height: 300rpx;  
  border-radius: 20rpx;
}
.main .review .foot .text{
  width: 690rpx;
  height: 45rpx;
  font-size: 28rpx;
  color: #fff;
  text-align: center;
  background: rgb(0,0,0);
  opacity: 0.6;
  position: absolute;
  bottom: 0;
  border-radius: 0 0 10rpx 10rpx;
  padding-top: 15rpx;
  z-index: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}