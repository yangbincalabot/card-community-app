<!--pages/activity/apply/success/index.wxml-->
<view class='main'>
    <view class="pay_box">
        <view class='pay'>
            <image src='https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/pay_icon.png'></image>
            <view class='p1'>报名成功</view>
            <view class='p2'>订单号：{{ detail.order_no }}</view>
            <view class='p3'>支付金额：{{ detail.price }}元</view>
        </view>
    </view>
    <view class='back' bindtap="switchTabToUrl" data-url="/pages/activity/index/index">完成</view>
</view>
