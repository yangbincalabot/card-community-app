<!--pages/activity/apply/index/index.wxml-->
<view class="main" hidden="{{ mainHidden }}">
    <form bindsubmit="formSubmit" bindreset="formReset">
    <view class="active_msg">
        <view class="active_box">
            <view class="title">活动信息</view>
        </view>
        <view class="msg">
            <view class="img">
                <image src="{{ detail.activity.cover_image }}"></image>
            </view>
            <view class="text">
                <view class="text_title">{{ detail.activity.title }}</view>
                <view class="price_box">
                    <text>{{ detail.spe.title }}</text>
                </view>
                <view class="price">￥{{ detail.spe.price }}</view>
            </view>
        </view>
    </view>
    <view class="ct_box">
        <view class="ct">
            报名人信息
        </view>
        <view class="ct">
            <view class="ct_left">姓名</view>
            <view class="ct_right">
                <input value="{{ detail.carte.name }}" name="name" ></input>
            </view>
        </view>
        <view class="ct">
            <view class="ct_left">手机号</view>
            <view class="ct_right">
                <input value="{{ detail.carte.phone }}" name="phone" ></input>
            </view>
        </view>
        <view class="ct">
            <view class="ct_left">工作单位</view>
            <view class="ct_right">
                <input value="{{ detail.carte.company_name }}" name="company_name"></input>
            </view>
        </view>
    </view>
    <view class="footer">
        <view class="footer_left">
            应付金额：{{ detail.spe.price }}
        </view>
        <!--  data-url="../signUpSuccess/signUpSuccess" 当支付金额等于0 -->
        <button class="now" formType="submit" >立即报名</button>
    </view>
    </form>
</view>
