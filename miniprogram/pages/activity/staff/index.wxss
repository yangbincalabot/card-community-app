/* pages/activity/staff/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.head_title{
    width:738rpx;
    height:46rpx;
    /* background:linear-gradient(180deg,rgba(255,202,123,1) 0%,rgba(255,155,5,1) 100%); */
    /* padding-left: 12rpx; */
    padding: 24rpx;
    display: flex;
    align-items: center;
    background: #fff;
    padding-left: 25rpx;
    border-bottom: 1rpx solid #eeeeee;
}
.head_title text{
  font-size: 32rpx;
  color: #666666;
}
.ct_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
    margin-bottom: 120rpx;
}
.ct{
    width: 690rpx;
    border-bottom: 1rpx solid #eeeeee;
    padding: 28rpx 0;
    margin: 0 auto;
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #888888;
}
.ct image{
    width: 50rpx;
    height: 50rpx;
    border-radius: 90rpx;
}
.title{
    font-size: 32rpx;
    color: #000000;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
}
.title span{
    font-size: 24rpx;
    color: #878787;
    margin-left: 34rpx;
}
.text{
    /* width: 415rpx;
     */
    flex: 1;
    margin-left: 22rpx;
    margin-right: 15rpx;
    font-size: 28rpx;
    color: #878787;
    line-height: 50rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.footer{
    width: 100%;
    height: 98rpx;
    display: flex;
    align-items: center;
    position: fixed;
    bottom: 0;
    z-index: 8;
    background: #FFFFFF;
    box-shadow: 0 2px 12px 0 rgba(0, 0, 0, .5);
}
.footer .footer_item{
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.footer .footer_item .imgBox{
  width: 50rpx;
  height: 50rpx;
}
.footer .footer_item .imgBox image{
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}
.footer .footer_item:nth-of-type(2) .imgBox image{
   width: 90%;
  height: 90%;
}
.footer .footer_item:nth-of-type(4) .imgBox image{
 width: 90%;
  height: 90%;
}
.footer .footer_item .textt{
  font-size: 10px;
}
.yuyue_yes{
  font-size: 26rpx;
  color: white;
  background: #50A6F9;
  width: 200rpx;
  height: 55rpx;
  border-radius: 10rpx;
  text-align: center;
  line-height: 55rpx;
}

.yuyue_no{
  font-size: 26rpx;
  color: #50A6F9;
  width: 200rpx;
  height: 55rpx;
  border-radius: 10rpx;
  text-align: center;
  line-height: 55rpx;
  border:1rpx solid #50A6F9; 
}

.yuyue_self{
  color: #666666;
  border:1rpx solid #666666; 
}