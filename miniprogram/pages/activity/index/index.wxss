/* pages/activity/index/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.main{
  background: #ffffff;
}
.search{
    width: 100%;
    height: 122rpx;
    background: #F4F4F4;
    display: flex;
    align-items: center;
    justify-content: center;
}
.search_input{
    width:700rpx;
    height:74rpx;
    background: #fff;
    border-radius:14rpx;
}
input{
    width: 660rpx;
    height: 54rpx;
    padding: 10rpx 20rpx;
    font-size: 28rpx;
    color: #333333;
    text-align: center;
}
.active-switch {
    overflow: scroll;
    margin-top: 20rpx;
}

.switch-container {
    width: 750rpx;
    height: 100rpx;
    background: #ffffff;
    position: relative;
    display: -webkit-box;
    display: -webkit-flex;
    display: -ms-flexbox;
    display: flex;
    justify-content: space-around;
    -webkit-box-orient: horizontal;
    -webkit-box-direction: normal;
    -webkit-flex-direction: row;
    -ms-flex-direction: row;
    flex-direction: row;
    align-items: center;
}
.switch-container .focus::after{
  content: '';
  position: absolute;
  z-index: 10;
  bottom: 0;
  left: 70rpx;
  right: 70rpx;
  height: 0;
  border-bottom: 2px solid #50A6F9;
}

.focus-line {
    -webkit-box-flex: 1;
    -webkit-flex: 1;
    -ms-flex: 1;
    flex: 1;
    position: absolute;
    bottom: 0;
    -webkit-transition: 0.3s;
    -o-transition: 0.3s;
    transition: 0.3s;
}

.active-item {
    position: relative;
    -webkit-box-flex: 1;
    -webkit-flex: 1;
    -ms-flex: 1;
    flex: 1;
    height: 40px;
    -webkit-transition: .3s;
    -o-transition: .3s;
    transition: .3s;
    color: #7F7F7F;
    text-align: center;
    display: -webkit-box;
    display: -webkit-flex;
    display: -ms-flexbox;
    display: flex;
    -webkit-box-orient: vertical;
    -webkit-box-direction: normal;
    -webkit-flex-direction: column;
    -ms-flex-direction: column;
    flex-direction: column;
    -webkit-justify-content: space-around;
    -ms-flex-pack: distribute;
    justify-content: space-around;
}

.focus {
    color: #000000;
    -webkit-transition-duration: .3s;
    -o-transition-duration: .3s;
    transition-duration: .3s;
    position: relative;
    -webkit-box-flex: 1;
    -webkit-flex: 1;
    -ms-flex: 1;
    flex: 1;
    height: 40px;
    -webkit-transition: .3s;
    -o-transition: .3s;
    transition: .3s;
    text-align: center;
    display: -webkit-box;
    display: -webkit-flex;
    display: -ms-flexbox;
    display: flex;
    -webkit-box-orient: vertical;
    -webkit-box-direction: normal;
    -webkit-flex-direction: column;
    -ms-flex-direction: column;
    flex-direction: column;
    -webkit-justify-content: space-around;
    -ms-flex-pack: distribute;
    justify-content: space-around;
}

.item {
    padding: 0 2rpx;
    overflow: hidden;
    font-size: 32rpx;
}
.ct_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
}
.ct{
    width: 710rpx;
    border-bottom: 1rpx solid #eeeeee;
    margin: 0 auto;
    padding: 22rpx 0 0 0;
}
.ct_msg{
    width: 710rpx;
    display: flex;
    align-items: center;
}
.msg_left{
    width:224rpx;
    height:182rpx;
    position: relative;
}
.msg_left image{
    width:224rpx;
    height:182rpx;
    border-radius: 10rpx;
}
.msg_left text{
    position: absolute;
    font-size:24rpx;
    color: #FFFFFF;
    height:38rpx;
    background:rgba(255,193,99,1);
    z-index: 1;
    left: 0;
    padding: 0 14rpx;
    border-radius: 7rpx 0;
}
.msg_right{
    margin-left: 14rpx;
    line-height: 40rpx;
}
.msg_title{
    font-size: 28rpx;
    color: #303133;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.msg_text{
    font-size: 24rpx;
    color: #909399;
    margin-top: 20rpx;
    width: 472rpx;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
}
.iconshijian,.iconlocation{
    font-size: 26rpx;
    margin-right: 5rpx;
}
.all{
    width: 710rpx;
    margin: 20rpx auto;
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #909399;
}
.all span{
  padding: 2rpx 8rpx;
  border: 1px solid #50A6F9;
  color:#50A6F9;
  margin-left: 4rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}
.all image{
    width: 52rpx;
    height: 52rpx;
    border-radius: 90rpx;
    margin-right: -10rpx;
}
  .imgs{
    max-width: 370rpx;
    height: 52rpx;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
    padding-right: 25rpx;
    border-radius: 25rpx;
  }
  .all text{   
    width: 160rpx;
    margin-left: 20rpx;
  }
.meeting text{
    background:linear-gradient(180deg,rgba(68,153,241,1) 0%,rgba(4,121,242,1) 100%);
    border-radius: 0 4rpx 4rpx 0;
}
/* 下拉 */
.down{
    z-index: 2;
}
.down_box{
    width: 100%;
    height: 100%;
    position: fixed;
    z-index: 2;
    background: rgba(0, 0, 0, .5);

}
.down_msg{
    width: 100%;
    height: 264rpx;
    background: #ffffff;
    position: absolute;
    z-index: 3;
}
.down_ct{
    width: 710rpx;
    height: 88rpx;
    border-top: 1rpx solid #eeeeee;
    margin: 0 auto;
    display: flex;
    align-items: center;
    font-size: 32rpx;
    color: #B5B5B5;
}
.downActive{
    color: #ffffff;
}
.down{
  position: absolute;
  z-index: 3;
  right: 12rpx;
  padding: 20rpx 50rpx;
  border-radius: 14rpx;
  background: rgb(75,75, 75);
  margin-top: -25rpx;
  font-size: 32rpx;
  color: #ffffff;
  line-height: 90rpx;
}
.down image{
  width: 30rpx;
  height: 30rpx;
   margin-right: 30rpx;
}
.active{
  color: #ffffff;
}
.iconshengxu{
    position: absolute;
    right: 42rpx;
    z-index: 3;
    margin-top: -38rpx;
    color: rgb(75,75, 75);
}
.mask-pod{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
}