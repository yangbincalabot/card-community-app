/* pages/supply/index/index.wxss */
page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.main{
    position: relative;
}
.search{
    width: 100%;
    height: 65rpx;
    background:  #f5f5f5;
    display: flex;
    align-items: center;
}
.search_input{
    width:560rpx;
    height:74rpx;
    background: #ffffff;
    border-radius:14rpx;
    margin-left: 20rpx;
}
input{
    width: 520rpx;
    height: 54rpx;
    padding: 10rpx 20rpx;
    font-size: 28rpx;
    color: #333333;
    text-align: center;
}
.all{
    font-size: 32rpx;
    color: #000000;
    margin-left: 32rpx;
    display: flex;
    align-items: center;
}
.all text{
    width: 65rpx;
    overflow: hidden;
    white-space: nowrap;
}
.ct_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
    margin: 20rpx auto;
}
.ct{
    width: 710rpx;
    border-bottom: 1rpx solid #eeeeee;
    margin: 0 auto;
    padding: 18rpx 0;
    display: flex;
}
.ct image{
    width: 112rpx;
    height: 112rpx;
    /* border-radius: 90rpx; */
}
.ct_right{
    margin-left: 20rpx;
    font-size: 28rpx;
    color: #000000;
}
.name{
    font-size: 36rpx;
}
.name span{
    height:42rpx;
    /* background:linear-gradient(180deg,rgba(69,153,241,1) 0%,rgba(3,120,242,1) 100%); */
    background-color: rgba(69,153,241,1);
    /* border-radius:14rpx; */
    padding: 5rpx 20rpx;
    font-size: 24rpx;
    color: #FFFFFF;
    margin-left: 20rpx;
}
.msg{
    margin: 0rpx auto;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    font-size: 24rpx;
    color: #939393;
}
.text{
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.trivia{
    width: 578rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 5rpx;
    font-size: 24rpx;
    color: #939393;
}
.btn{
    display: flex;
    align-items: center;
}
.btn1,.btn2{
    height: 50rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 30rpx;
}
.btn1{
    border-radius:14rpx;
    border:2rpx solid rgba(255,147,0,1);
    background: #ffffff;
    font-size: 24rpx;
    color: #FF9300;
}
.btn2{
    font-size: 24rpx;
    color: #FFFFFF;
    /* background:linear-gradient(180deg,rgba(117,117,117,1) 0%,rgba(0,0,0,1) 100%); */
    border: 1rpx solid #aaa;
    color: #aaa;
    border-radius:14rpx;
    margin-left: 20rpx;
}
.icondianzan{
    margin-right: 10rpx;
}
.imgs{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    margin: 5rpx auto;
}
.imgs image{
    width: 180rpx;
    height: 180rpx;
    border-radius: 10rpx;
    margin : 0 12rpx 12rpx 0;
}
.down{
    position: absolute;
    z-index: 3;
    right: 12rpx;
    padding: 12rpx 40rpx;
    background: rgba(75,75,75,1);
    border-radius: 14rpx;
    margin-top: 15rpx;
    font-size: 32rpx;
    color: #ffffff;
    line-height: 60rpx;
}
.active{
  color: #ffffff
}
.iconshengxu{
    position: absolute;
    right: 42rpx;
    z-index: 3;
    margin-top: -50rpx;
}