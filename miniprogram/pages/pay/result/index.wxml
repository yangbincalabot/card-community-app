<!--pages/paysuccess/index.wxml-->
<view class='main'>
    <view class='pay'>
        <image src='https://szdbi.oss-cn-shenzhen.aliyuncs.com/dule/pay_icon.png'></image>
        <view class='p1'>{{orderInfo.payment_method == 'offline_pay' ? '提醒成功，请等待确认' : '支付成功'}}</view>
        <view class='p2'>订单号：{{orderInfo.no}}</view>
        <view class='p3'>支付金额：{{orderInfo.total_amount}}元</view>
        <view class='back' bindtap="backToCart">返回</view>
        <view class='check' bindtap="viewOrderDetail">查看订单</view>
    </view>
</view>
