<!--pages/pay/index/index.wxml-->
<view class='main'>
    <view class='money'>
        <view class='ct'>
            <view class='c1'>订单金额</view>
            <view class='c2'><i>￥{{ orderDetail.price }}</i>元</view>
        </view>
    </view>
    <view class='content'>
        <view class='c1'>选择支付方式</view>
        <view class='wx' bindtap="changeType" data-type="1">
            <view>
                <i class='icon iconfont iconweixin'></i>
                微信支付
            </view>
            <icon wx:if="{{pay_type == 1}}" type="success" color="rgb(0,0,0,.5)"></icon>
            <icon wx:else type="circle"></icon>
        </view>
        <view class='offline' bindtap="changeType" data-type="2">
            <view>
                <i class='icon iconfont iconyue'></i>
                余额支付<block wx:if="{{ (balance.money-orderDetail.price) < 0 }}"><span class="redspan"> (余额不足)</span></block>
            </view>
            <icon wx:if="{{pay_type == 2}}" type="success" color="rgb(0,0,0,.5)"></icon>
            <icon wx:else type="circle"></icon>
        </view>
    </view>
    <!--  bindtap="masks" 余额支付跳转输入密码框 -->
    <view class='payment' bindtap="payment">
        立即支付
    </view>
    <!-- 提现密码输入 -->
    <view wx-if="{{mask}}" class="pwd_box">
        <view :class="{{bott}}" class="masks">
            <view class="pwd_six_title">
                <view bindtap="maskss" class="icon iconfont iconshanchu1" style="color: #CCCCCC;"></view>
                <view>请输入支付密码</view>
            </view>
            <view class="pwd_six_box">
                <view class="box">
                    <view class="box_border">
                        <text wx-if="{{passArray.length > 0}}" class="pwd_hide">●</text>
                    </view>
                </view>
                <view class="box">
                    <view class="box_border">
                        <text wx-if="{{passArray.length > 1}}" class="pwd_hide">●</text>
                    </view>
                </view>
                <view class="box">
                    <view class="box_border">
                        <text wx-if="{{passArray.length > 2}}" class="pwd_hide">●</text>
                    </view>
                </view>
                <view class="box">
                    <view class="box_border">
                        <text wx-if="{{passArray.length > 3}}" class="pwd_hide">●</text>
                    </view>
                </view>
                <view class="box">
                    <view class="box_border">
                        <text wx-if="{{passArray.length > 4}}" class="pwd_hide">●</text>
                    </view>
                </view>
                <view class="box">
                    <view class="box_border" style="border-right: 1rpx solid #bfbfbf;">
                        <text wx-if="{{passArray.length > 5}}" class="pwd_hide">●</text>
                    </view>
                </view>
            </view>
            <view class="number">
                <view bindtap="getPassword" data-value="1" class="password" style="border-left: 0;">1</view>
                <view bindtap="getPassword" data-value="2" class="password">2</view>
                <view bindtap="getPassword" data-value="3" class="password">3</view>
                <view bindtap="getPassword" data-value="4" class="password" style="border-left: 0;">4</view>
                <view bindtap="getPassword" data-value="5" class="password">5</view>
                <view bindtap="getPassword" data-value="6" class="password">6</view>
                <view bindtap="getPassword" data-value="7" class="password" style="border-left: 0;">7</view>
                <view bindtap="getPassword" data-value="8" class="password">8</view>
                <view bindtap="getPassword" data-value="9" class="password">9</view>
                <view bindtap="reset" class="password" style="background: #EEEEEE;color: #fff;"></view>
                <view bindtap="getPassword" data-value="0" class="password">0</view>
                <view bindtap="backspace" class="password" style="background: #EEEEEE;color: #fff;"><span class="icon iconfont iconcs-sc-1" style="font-size: 50rpx;color: #FFFFFF;"></span></view>
            </view>
        </view>
    </view>
</view>
