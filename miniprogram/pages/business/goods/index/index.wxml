<view class="main" bindtap="closeActive">
    <view class="show">
        <view class='content'>
            <view class="ct_view">
                <block wx:for="{{ goods }}" wx:key="index">
                    <view class="active_box">
                        <view class="active_view">
                            <navigator hover-class="none" url="/pages/card/goodsDetail/goodsDetail?id={{ item.id }}">
                                <view class="ct">
                                    <view class="img">
                                        <image src="{{item.image}}"></image>
                                    </view>
                                    <view class="text">
                                        <view class="ct_title">{{item.title}}</view>
                                        <view class="ct_time">创建时间：{{item.created_at}}</view>
                                        <view class="ct_status">
                                            <view class="ct_num">价格：{{ item.price }}</view>
                                            <view class="ct_num">状态：{{item.is_show ? '已上架' : '已下架'}}</view>
                                            <view class="ct_sta">销量：{{item.sales}}</view>
                                            
                                        </view>
                                    </view>
                                </view>
                            </navigator>
                            
                            <view class="btn">
                                <button bindtap="changeShow" data-index="{{ index }}" data-id="{{ item.id }}"  hover-class="none">
                                <block wx:if="{{ item.is_show === true }}">
                                    下架
                                </block>
                                <block wx:else>
                                    上架
                                </block>
                                </button>

                                <button bindtap="delete" data-index="{{ index }}" data-id="{{ item.id }}"  hover-class="none">删除</button>
                                <navigator url="../update/update?id={{ item.id }}" hover-class="none">
                                    <button  hover-class="none">编辑</button>
                                </navigator>
                            </view>
                        </view>
                    </view>
                </block>
            </view>
        </view>

    </view>
    <navigator class="add" url="../add/add" hover-class="none">
        <view class="icon iconfont iconjia1"></view>
    </navigator>

</view>