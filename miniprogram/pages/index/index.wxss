.change{
  width:94rpx;
  height:94rpx;
  background:linear-gradient(0deg,rgba(1,110,255,1) 0%,rgba(113,113,255,1) 100%);
  box-shadow:3rpx 3rpx 14rpx 0rpx rgba(1,110,255,0.54);
  border-radius:50%;
  position: fixed;
  bottom: 180rpx;
  right: 27rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.change image{
  width: 30rpx;
  height: 30rpx;
}
.mask-box{
  width: 100%;
  height: 100%;
  opacity: 0;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
}
.mask-top{
  height: 150rpx;
  width: 100%;
  background:linear-gradient(to bottom,rgba(0,0,0,0.5),rgba(255, 253, 253,0));
  position: absolute;
  top: 0rpx;
  left: 0rpx;
  z-index: 200;
}