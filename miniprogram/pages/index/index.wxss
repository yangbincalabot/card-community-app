/**index.wxss**/
.main{
  width: 750rpx;
  overflow: hidden;
}
page{
    width: 100%;
    height: 100%;
    /* background: #f5f5f5; */
}
.swiperX{
  position: relative;
}
.swiperX::after{
  content: '';
  position: absolute;
  z-index: 0;
  width: 140%;
  height: 200rpx;
  left: -20%;
  top:360rpx;
  border-radius: 50% 50% 0 0;
  background: #fff;
}
.swiperX .arc{
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  margin: auto;
  z-index: 20;
  width: 1000rpx;
  height: 1000rpx;
  border-radius: 50%;
  background: red;
}
.swiperX swiper,.swiperX image{
    width: 750rpx;
    height: 393rpx;
}
/* .swiperX swiper{
  overflow: hidden;
} */

.msg{
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-around;
    text-align: center;
    font-size: 28rpx;
    color: #303133;
    line-height: 50rpx;
    margin:28rpx auto;
    background: #ffffff;
    padding: 20rpx 0;
    /* border-radius: 50rpx !important;
     */
     position: relative;
     margin-top: 0;
}
.msg image{
    width: 80rpx;
    height: 80rpx;
}
.swiper_box{
    width: 96%;
    height: 84rpx;
    background: #ffffff;
    box-shadow:1px 0px 3px 3px rgba(144,144,144,0.2);
    display: flex;
    align-items: center;
    margin: 0 auto;
    border-radius: 10rpx;
}
.swiper-msg{
    height: 70rpx;
    width: 710rpx;
    display: flex;
    align-items: center;
    margin: 0 auto;
    font-size: 28rpx;
    color: #FFC163;
}
.swiper-msg swiper{
    width: 560rpx;
    height: 70rpx;
}
.iconlabax{
    font-size: 46rpx;
    color: #FFC163;
    display: flex;
    align-items: center;
    margin-right: 20rpx;
    margin-left: 15rpx;
}
.down{
    height: 70rpx;
    font-size: 28rpx;
    color: #909399;
    display: flex;
    align-items: center;
}
.active_title{
    width: 710rpx;
    margin: 20rpx auto;
    font-size: 28rpx;
    color: #000000;

}
.ct_box{
    width: 100%;
    height: 100%;
    background: #ffffff;
    margin-bottom: 150rpx;
}
.ct{
    width: 710rpx;
    border-bottom: 1rpx solid #eeeeee;
    margin: 0 auto;
    padding: 22rpx 0 0 0;
}
.ct_msg{
    width: 710rpx;
    display: flex;
    align-items: center;
}
.msg_left{
    width:224rpx;
 
    height:150rpx;
    position: relative;
}
.msg_left image{
    width:224rpx;
    height:150rpx;
    border-radius: 10rpx;
}
.msg_left text{
    position: absolute;
    font-size:24rpx;
    color: #FFFFFF;
    height:38rpx;
    background:rgba(255,193,99,1);
    z-index: 1;
    left: 0;
    padding: 0 14rpx;
    border-radius: 7rpx 0;
}
.msg_right{
    margin-left: 14rpx;
    line-height: 40rpx;
}
.msg_title{
    font-size: 30rpx;
    color: #303133;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.msg_text text{
  font-size: 26rpx;
}
.msg_text{
    font-size: 24rpx;
    color: #909399;
    margin-top: 20rpx;
    width: 472rpx;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
}
.iconshijian,.iconlocation{
    font-size: 26rpx;
    margin-right: 5rpx;
}
.all{
    width: 710rpx;
    margin: 20rpx auto;
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #909399;
}
.all image{
    width: 52rpx;
    height: 52rpx;
    border-radius: 90rpx;
    margin-right: -10rpx;
}
.imgs{
    max-width: 445rpx;
    height: 52rpx;
    overflow: hidden;
    text-overflow:ellipsis;
    white-space: nowrap;
    padding-right: 25rpx;
    border-radius: 25rpx;
}
.all text{
    width: 200rpx;
    margin-left: 20rpx;
}

.meeting text{
    background:linear-gradient(180deg,rgba(68,153,241,1) 0%,rgba(4,121,242,1) 100%);
    /* border-radius: 0 4rpx 4rpx 0; */
}

/* 我的供需，数字角标 */
  .msg_imgBox{
    position: relative
  }
  .msg_imgBox .number_tip{
    position: absolute;
    top:-10rpx;
    right: 20rpx;
    /* padding:0 10rpx; */
    border-radius: 50%;
    background: #e75345;
    color: #fff;
    font-size: 12px;
    line-height: 37rpx;
    height: 37rpx;
    width: 37rpx;
    text-align: center;
  }
  .number_tip.number_tip_big{
    height: 47rpx;
    width: 47rpx;
    line-height: 47rpx;
  }
/* 底部导航栏 */
  .tabbar{
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100rpx;
    /* border-top: 0.5px solid #d5d5d5; */
    box-shadow: 0 1px 6px #ccc;
    display: flex;
    font-size: 0;
    background: rgba(255, 255, 255, 0.9);
    z-index: 99;
  }
  .tabbar .tabbar_item{
    flex: 1;
    text-align: center;
    overflow: hidden;
    box-sizing: border-box;
    padding: 12rpx 10rpx 0;
    color: #333333;
  }
  .tabbar .tabbar_item:nth-child(3){
    padding-bottom: 12rpx;
    flex: 0.7;
    /* position: relative; */
  }
  .tabbar .tabbar_item:nth-child(3) .addImg{
    width: 114rpx;
    height: 114rpx;
    position: absolute;
    z-index: 200;
    left: 0;
    right: 0;
    margin: auto;
    top: -22rpx;

  }
  .create{
    position: fixed;
    width: 300rpx;
    height: 300rpx;
    bottom: 140rpx;
    left: 0;
    right: 0;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #4b4b4b;
    color: #fff;
    z-index: 999;
    border-radius: 20rpx;
    box-shadow: 0 2px 12px 0 rgba(75,75,75, 0.3);
  }
  .create .item{
    display: flex;
    align-items: center;
    padding: 26rpx;
    box-sizing: border-box;
    border-bottom: 1px solid #4f4f4f;
    font-size: 28rpx;
  }
  .create .item:last-of-type{
    border: none;
  }
