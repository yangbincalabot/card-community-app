page{
    width: 100%;
    height: 100%;
    background: #f5f5f5;
}
.swiper-tab{
    width: 100%;
    text-align: center;
    height: 90rpx;
    line-height: 90rpx;
    display: flex;
    justify-content: space-around;
    flex-flow: row;
    font-size: 30rpx;
    background: #ffffff;
}
.swiper-tab-item{
    width: 25%;
    color:#333333;
}
.active{
    color:#50A6F9;
    border-bottom: 6rpx solid #50A6F9;
}
.show{
    display: block;
}
.hidden{
    display: none;
}
.time{
    width: 710rpx;
    margin: 0 auto;
}
.time_title{
    padding: 20rpx 0;
    font-size: 26rpx;
    color: #333333;
}
.user{
    width: 710rpx;
    border-radius: 10rpx;
    background: #ffffff;
    padding: 30rpx 0;
    margin-top: 2rpx;
    position: relative;
}
.user_ct{
    width: 650rpx;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.user_img{
    display: flex;
    align-items: center;
    font-size: 26rpx;
    color: #999999;
    width: 520rpx;
}
.user_img image{
    width: 80rpx;
    height: 80rpx;
    border-radius: 90rpx;
}
.user_name{
    margin-left: 30rpx;
    line-height: 40rpx;
}
.name{
    font-size: 30rpx;
    color: #333333;
}
.add_user{
    font-size: 26rpx;
    color: #999999;
    padding: 5rpx 20rpx;
}
.add_time span{
    margin-left: 30rpx;
}
.user_image{
    width: 110rpx;
    position: relative;
}
.user_image span{
    position: absolute;
    background: #FE9c2A;
    color: #ffffff;
    font-size: 22rpx;
    border-radius: 10rpx;
    padding: 0 10rpx;
    z-index: 1;
    left: 20rpx;
    top: -5rpx;
    transform:rotate(25deg);
    line-height: 30rpx;
}
.notadd{
    color: #50A6F9;
    background: #f5f5f5;
    padding: 5rpx 20rpx;
    border-radius: 10rpx;
}
.accept{
    background: #50A6F9;
    color: #ffffff;
    padding: 5rpx 30rpx;
    border-radius: 10rpx;
}


.myrate{
  position: absolute;
  right: 10rpx;
  top:14rpx;
}

.rate{
  display: flex;
  align-items: center;
  position: absolute;
  right: 30rpx;
  top: 15rpx;
  z-index:30;
}
.rate image{
  width: 25rpx;
  height: 25rpx;
  margin-right: 10rpx;
}